%logic
// C++ Container File Template for PolyGen
// Generates data containers with indexes
// Ported from cpp_container_file.rhai → converted to 방식 A

import "templates/cpp/rhai_utils/type_mapping" as cpp_types;

// Check if struct has indexes defined
fn has_indexes(s) {
    if s.indexes != () && s.indexes.len() > 0 {
        return true;
    }
    return false;
}

// Get the fully qualified C++ type name
fn get_full_cpp_type(namespace_fqn, type_name) {
    if namespace_fqn == "" {
        return type_name;
    }
    let ns_cpp = namespace_fqn + "";
    ns_cpp.replace(".", "::");
    return "::" + ns_cpp + "::" + type_name;
}

fn get_cpp_type_from_fqn(fqn, fallback_name) {
    if fqn == () || fqn == "" {
        return fallback_name;
    }
    let result = fqn + "";
    result.replace(".", "::");
    return "::" + result;
}

fn find_table_entry_by_fqn(entries, fqn) {
    for entry in entries {
        if entry.struct_def.fqn == fqn {
            return entry;
        }
    }
    return ();
}

fn find_pk_field(struct_def) {
    for item in struct_def.items {
        if item.is_field() {
            let f = item.as_field();
            if f.is_primary_key {
                return f.name;
            }
        }
    }
    for idx in struct_def.indexes {
        if idx.is_unique {
            return idx.field_name;
        }
    }
    return "";
}

fn nav_field_label(field_name) {
    let label = cpp_types::to_snake_case(field_name);
    if label.ends_with("_id") && label.len() > 3 {
        return label.sub_string(0, label.len() - 3);
    }
    return label;
}

fn nav_method_suffix(source_table, field_name) {
    return cpp_types::to_snake_case(source_table.name) + "_" + nav_field_label(field_name);
}

fn reverse_nav_method_suffix(target_table, relation_name) {
    return cpp_types::to_snake_case(target_table.name) + "_" + cpp_types::to_snake_case(relation_name);
}

// Pluralize a name (simple version)
fn pluralize(name) {
    if name.ends_with("y") {
        return name.sub_string(0, name.len() - 1) + "ies";
    } else if name.ends_with("s") || name.ends_with("x") || name.ends_with("ch") || name.ends_with("sh") {
        return name + "es";
    } else {
        return name + "s";
    }
}

fn cpp_string_literal(value) {
    let escaped = value + "";
    escaped.replace("\\", "\\\\");
    escaped.replace("\"", "\\\"");
    return "\"" + escaped + "\"";
}

fn get_load_pattern(s, kind) {
    if s.load == () {
        return "";
    }
    if kind == "csv" && s.load.csv != () {
        return s.load.csv + "";
    }
    if kind == "json" && s.load.json != () {
        return s.load.json + "";
    }
    return "";
}

// Get C++ type for a single field type
fn get_field_cpp_type(t) {
    if t.is_primitive || cpp_types::is_primitive_name(t.type_name) {
        return cpp_types::map_primitive_type(t.type_name);
    } else {
        return get_full_cpp_type(t.namespace_fqn, t.type_name);
    }
}

// Get C++ type for index key (supports composite indexes)
fn get_index_key_type(index) {
    if index.is_composite {
        let types = [];
        for f in index.fields {
            types.push(get_field_cpp_type(f.field_type));
        }
        let result = "std::tuple<";
        for i in 0..types.len() {
            if i > 0 { result += ", "; }
            result += types[i];
        }
        result += ">";
        return result;
    } else {
        let t = index.field_type;
        return get_field_cpp_type(t);
    }
}

// Get field accessor expression for index insert
fn get_index_key_expr(index, row_var) {
    if index.is_composite {
        let result = "std::make_tuple(";
        for i in 0..index.fields.len() {
            if i > 0 { result += ", "; }
            result += row_var + "." + index.fields[i].name;
        }
        result += ")";
        return result;
    } else {
        return row_var + "." + index.field_name;
    }
}

fn search_type_name_to_cpp(type_name) {
    switch type_name {
        "string" => "std::string",
        "bool" => "bool",
        "u8" => "uint8_t",
        "u16" => "uint16_t",
        "u32" => "uint32_t",
        "u64" => "uint64_t",
        "i8" => "int8_t",
        "i16" => "int16_t",
        "i32" => "int32_t",
        "i64" => "int64_t",
        "timestamp" => "std::chrono::system_clock::time_point",
        _ => type_name
    }
}

fn search_is_string(field) {
    return field.field_type.type_name == "string";
}

fn search_is_supported(field) {
    if !field.has_search_index {
        return false;
    }
    let search = field.search_index;
    if search.target != "csharp" && search.target != "cpp" && search.target != "cpp_container" {
        return false;
    }
    if search.mode == "ngram" || search.mode == "word" {
        return field.field_type.type_name == "string";
    }
    return search.mode == "exact";
}

fn search_key_type(field) {
    let search = field.search_index;
    if search.mode == "ngram" || search.mode == "word" {
        return "std::string";
    }

    let t = field.field_type;
    if t.type_name == "string" {
        return "std::string";
    }
    if !t.is_primitive && t.namespace_fqn != "" {
        return get_full_cpp_type(t.namespace_fqn, t.type_name);
    }
    return search_type_name_to_cpp(t.type_name);
}

// Generate a table wrapper with indexes
fn generate_table_wrapper(s, namespace_fqn) {
    let result = "";
    let full_type = get_full_cpp_type(namespace_fqn, s.name);
    let table_name = s.name + "Table";
    let member_name = cpp_types::to_snake_case(pluralize(s.name));

    result += "// Table wrapper for " + s.name + " with indexes\n";
    result += "class " + table_name + " {\n";
    result += "public:\n";

    // Data storage
    result += "    polygen::DataTable<" + full_type + "> data;\n\n";

    // Index members
    if s.indexes != () {
        for idx in s.indexes {
            let key_type = get_index_key_type(idx);
            let index_member = idx.name;
            let hash_arg = if idx.is_composite { ", polygen::TupleHash" } else { "" };
            if idx.is_unique {
                result += "    polygen::UniqueIndex<" + key_type + ", " + full_type + hash_arg + "> " + index_member + ";\n";
            } else {
                result += "    polygen::GroupIndex<" + key_type + ", " + full_type + hash_arg + "> " + index_member + ";\n";
            }
        }
    }

    let search_indexes = [];
    for item in s.items {
        if item.is_field() {
            let field = item.as_field();
            if search_is_supported(field) {
                let search = field.search_index;
                let key_type = search_key_type(field);
                search_indexes.push(#{
                    name: search.name,
                    method_name: "search_by_" + cpp_types::to_snake_case(search.name),
                    field_name: field.name,
                    member_name: "search_" + cpp_types::to_snake_case(search.name),
                    key_type: key_type,
                    mode: search.mode,
                    n: search.n,
                    min: search.min,
                    normalize: search.normalize,
                    is_token_mode: search.mode == "ngram" || search.mode == "word",
                    is_string: search_is_string(field),
                    is_option: field.field_type.is_option
                });
            }
        }
    }

    for search in search_indexes {
        if search.is_token_mode {
            result += "    std::unordered_map<std::string, std::vector<" + full_type + "*>> " + search.member_name + ";\n";
        } else {
            result += "    polygen::GroupIndex<" + search.key_type + ", " + full_type + "> " + search.member_name + ";\n";
        }
    }

    result += "\n";

    // add_row method
    result += "    void add_row(" + full_type + "&& row) {\n";
    result += "        data.add_row(std::move(row));\n";
    result += "        auto& added = data[data.count() - 1];\n";

    if s.indexes != () {
        for idx in s.indexes {
            let key_expr = get_index_key_expr(idx, "added");
            result += "        " + idx.name + ".insert(" + key_expr + ", &added);\n";
        }
    }
    for search in search_indexes {
        if search.is_token_mode {
            if search.is_option {
                result += "        if (added." + search.field_name + ".has_value()) {\n";
                result += "            for (const auto& token : detail::search_tokens(*added." + search.field_name + ", \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\")) {\n";
                result += "                " + search.member_name + "[token].push_back(&added);\n";
                result += "            }\n";
                result += "        }\n";
            } else {
                result += "        for (const auto& token : detail::search_tokens(added." + search.field_name + ", \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\")) {\n";
                result += "            " + search.member_name + "[token].push_back(&added);\n";
                result += "        }\n";
            }
        } else if search.is_string {
            if search.is_option {
                result += "        if (added." + search.field_name + ".has_value()) {\n";
                result += "            " + search.member_name + ".insert(detail::search_normalize(*added." + search.field_name + ", \"" + search.normalize + "\"), &added);\n";
                result += "        }\n";
            } else {
                result += "        " + search.member_name + ".insert(detail::search_normalize(added." + search.field_name + ", \"" + search.normalize + "\"), &added);\n";
            }
        } else {
            if search.is_option {
                result += "        if (added." + search.field_name + ".has_value()) {\n";
                result += "            " + search.member_name + ".insert(*added." + search.field_name + ", &added);\n";
                result += "        }\n";
            } else {
                result += "        " + search.member_name + ".insert(added." + search.field_name + ", &added);\n";
            }
        }
    }

    result += "    }\n\n";

    result += "    void add_row(const " + full_type + "& row) {\n";
    result += "        add_row(" + full_type + "(row));\n";
    result += "    }\n\n";

    result += "    void load_all(const std::vector<" + full_type + ">& rows) {\n";
    result += "        for (const auto& row : rows) add_row(row);\n";
    result += "    }\n\n";

    result += "    void load_all(std::vector<" + full_type + ">&& rows) {\n";
    result += "        for (auto& row : rows) add_row(std::move(row));\n";
    result += "    }\n\n";

    // Accessor methods
    result += "    size_t count() const { return data.count(); }\n";
    result += "    bool empty() const { return data.empty(); }\n\n";

    // get_by_X methods
    if s.indexes != () {
        for idx in s.indexes {
            let key_type = get_index_key_type(idx);
            let getter_name = if idx.is_composite {
                "get_" + idx.name
            } else {
                "get_by_" + idx.field_name
            };

            if idx.is_unique {
                result += "    " + full_type + "* " + getter_name + "(const " + key_type + "& key) {\n";
                result += "        return " + idx.name + ".get(key);\n";
                result += "    }\n\n";
                result += "    const " + full_type + "* " + getter_name + "(const " + key_type + "& key) const {\n";
                result += "        return const_cast<" + table_name + "*>(this)->" + idx.name + ".get(key);\n";
                result += "    }\n\n";
            } else {
                result += "    const std::vector<" + full_type + "*>& " + getter_name + "(const " + key_type + "& key) const {\n";
                result += "        return " + idx.name + ".get(key);\n";
                result += "    }\n\n";
            }
        }
    }
    for search in search_indexes {
        if search.is_token_mode {
            result += "    std::vector<" + full_type + "*> " + search.method_name + "(const std::string& query) const {\n";
            result += "        return detail::search_intersect(" + search.member_name + ", query, \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\");\n";
            result += "    }\n\n";
        } else if search.is_string {
            result += "    std::vector<" + full_type + "*> " + search.method_name + "(const std::string& key) const {\n";
            result += "        return detail::copy_search_results(" + search.member_name + ".get(detail::search_normalize(key, \"" + search.normalize + "\")));\n";
            result += "    }\n\n";
        } else {
            result += "    std::vector<" + full_type + "*> " + search.method_name + "(const " + search.key_type + "& key) const {\n";
            result += "        return detail::copy_search_results(" + search.member_name + ".get(key));\n";
            result += "    }\n\n";
        }
    }

    // Iterator support
    result += "    auto begin() { return data.begin(); }\n";
    result += "    auto end() { return data.end(); }\n";
    result += "    auto begin() const { return data.begin(); }\n";
    result += "    auto end() const { return data.end(); }\n\n";

    // Clear method
    result += "    void clear() {\n";
    result += "        data.clear();\n";
    if s.indexes != () {
        for idx in s.indexes {
            result += "        " + idx.name + ".clear();\n";
        }
    }
    for search in search_indexes {
        result += "        " + search.member_name + ".clear();\n";
    }
    result += "    }\n\n";

    // Validate method
    result += "    /// Validates all rows against field constraints.\n";
    result += "    polygen::ValidationResult validate() const {\n";
    result += "        polygen::ValidationResult result;\n";
    result += "        for (const auto& row : data) {\n";

    // Get primary key expression for error messages
    let pk_expr = "\"\"";
    if s.indexes != () {
        for idx in s.indexes {
            if idx.name == "by_id" || idx.field_name == "id" {
                pk_expr = "std::to_string(row.id)";
                break;
            }
        }
    }

    // Validate each field with constraints
    for item in s.items {
        if item.is_field() {
            let field = item.as_field();
            let field_name = field.name;
            let is_option = field.field_type.is_option;
            let type_name = field.field_type.type_name;

            // MaxLength validation
            if field.max_length != () {
                let max_len = field.max_length;
                if is_option {
                    result += "            if (row." + field_name + ".has_value() && row." + field_name + "->length() > " + max_len + ") {\n";
                    result += "                result.add_error(polygen::validation::max_length_error(\n";
                    result += "                    \"" + s.name + "\", \"" + field_name + "\", " + pk_expr + ", " + max_len + ", row." + field_name + "->length()));\n";
                    result += "            }\n";
                } else if type_name == "string" {
                    result += "            if (row." + field_name + ".length() > " + max_len + ") {\n";
                    result += "                result.add_error(polygen::validation::max_length_error(\n";
                    result += "                    \"" + s.name + "\", \"" + field_name + "\", " + pk_expr + ", " + max_len + ", row." + field_name + ".length()));\n";
                    result += "            }\n";
                }
            }

            // Range validation
            if field.range != () {
                let min_val = field.range.min;
                let max_val = field.range.max;
                let cpp_type = get_field_cpp_type(field.field_type);
                let cast_min = "static_cast<" + cpp_type + ">(" + min_val + ")";
                let cast_max = "static_cast<" + cpp_type + ">(" + max_val + ")";
                result += "            if (!polygen::validation::validate_range(row." + field_name + ", " + cast_min + ", " + cast_max + ")) {\n";
                result += "                result.add_error(polygen::validation::range_error(\n";
                result += "                    \"" + s.name + "\", \"" + field_name + "\", " + pk_expr + ", " + cast_min + ", " + cast_max + ", row." + field_name + "));\n";
                result += "            }\n";
            }

            // Regex validation
            if field.regex_pattern != () {
                let pattern = field.regex_pattern;
                let escaped_pattern = pattern;
                escaped_pattern.replace("\\", "\\\\");
                if is_option {
                    result += "            if (row." + field_name + ".has_value() && !polygen::validation::validate_regex(*row." + field_name + ", R\"(" + pattern + ")\")) {\n";
                    result += "                result.add_error(polygen::validation::regex_error(\n";
                    result += "                    \"" + s.name + "\", \"" + field_name + "\", " + pk_expr + ", R\"(" + pattern + ")\", *row." + field_name + "));\n";
                    result += "            }\n";
                } else if type_name == "string" {
                    result += "            if (!polygen::validation::validate_regex(row." + field_name + ", R\"(" + pattern + ")\")) {\n";
                    result += "                result.add_error(polygen::validation::regex_error(\n";
                    result += "                    \"" + s.name + "\", \"" + field_name + "\", " + pk_expr + ", R\"(" + pattern + ")\", row." + field_name + "));\n";
                    result += "            }\n";
                }
            }
        }
    }

    result += "        }\n";
    result += "        return result;\n";
    result += "    }\n\n";

    // ValidateForeignKeys method
    result += "    /// Validates foreign key references exist in related tables.\n";
    result += "    template<typename Container>\n";
    result += "    polygen::ValidationResult validate_foreign_keys(const Container& container) const {\n";
    result += "        polygen::ValidationResult result;\n";

    let has_fk = false;
    for item in s.items {
        if item.is_field() {
            let field = item.as_field();
            if field.foreign_key != () {
                has_fk = true;
            }
        }
    }

    if !has_fk {
        result += "        // No foreign key constraints to validate\n";
        result += "        (void)container; // Suppress unused variable warning\n";
    } else {
        result += "        for (const auto& row : data) {\n";

        for item in s.items {
            if item.is_field() {
                let field = item.as_field();
                if field.foreign_key != () {
                    let fk = field.foreign_key;
                    let target_parts = fk.target_table_fqn.split(".");
                    let target_table = "";
                    for part in target_parts {
                        target_table = part;
                    }
                    let target_member = cpp_types::to_snake_case(pluralize(target_table));

                    if field.field_type.is_option {
                        result += "            if (row." + field.name + ".has_value()) {\n";
                        result += "                // Check FK reference to " + target_table + "\n";
                        result += "                if (container." + target_member + ".get_by_" + fk.target_field + "(row." + field.name + ".value()) == nullptr) {\n";
                        result += "                    result.add_error(polygen::validation::foreign_key_error(\n";
                        result += "                        \"" + s.name + "\", \"" + field.name + "\", " + pk_expr + ",\n";
                        result += "                        \"" + target_table + "\", std::to_string(row." + field.name + ".value())));\n";
                        result += "                }\n";
                        result += "            }\n";
                    } else {
                        result += "            // Check FK reference to " + target_table + "\n";
                        result += "            if (container." + target_member + ".get_by_" + fk.target_field + "(row." + field.name + ") == nullptr) {\n";
                        result += "                result.add_error(polygen::validation::foreign_key_error(\n";
                        result += "                    \"" + s.name + "\", \"" + field.name + "\", " + pk_expr + ",\n";
                        result += "                    \"" + target_table + "\", std::to_string(row." + field.name + ")));\n";
                        result += "            }\n";
                    }
                }
            }
        }

        result += "        }\n";
    }

    result += "        return result;\n";
    result += "    }\n";

    result += "};\n";

    return result;
}

// Convert snake_case or kebab-case to PascalCase
fn to_pascal_case(name) {
    let result = "";
    let capitalize_next = true;
    for i in 0..name.len() {
        let c = name.sub_string(i, 1);
        if c == "_" || c == "-" {
            capitalize_next = true;
        } else if capitalize_next {
            result += c.to_upper();
            capitalize_next = false;
        } else {
            result += c;
        }
    }
    return result;
}

// Generate the main container class body
fn generate_container(base_name, tables) {
    let result = "";
    let container_name = to_pascal_case(base_name) + "Container";
    let forward_navs = [];
    let reverse_navs = [];

    for entry in tables {
        let source = entry.struct_def;
        let source_type = get_cpp_type_from_fqn(source.fqn, source.name);
        for item in source.items {
            if item.is_field() {
                let field = item.as_field();
                if field.foreign_key != () {
                    let fk = field.foreign_key;
                    let target_entry = find_table_entry_by_fqn(tables, fk.target_table_fqn);
                    if target_entry != () {
                        let target = target_entry.struct_def;
                        forward_navs.push(#{
                            method_name: "get_" + nav_method_suffix(source, field.name),
                            source_type: source_type,
                            field_name: field.name,
                            target_type: get_cpp_type_from_fqn(target.fqn, target.name),
                            target_member: cpp_types::to_snake_case(pluralize(target.name)),
                            target_method: "get_by_" + cpp_types::to_snake_case(fk.target_field),
                            is_optional: field.field_type.is_option
                        });
                    }
                }
            }
        }
    }

    for entry in tables {
        let target = entry.struct_def;
        let target_pk = find_pk_field(target);
        if target_pk == "" {
            target_pk = "id";
        }
        for rel in target.relations {
            let source_entry = find_table_entry_by_fqn(tables, rel.source_table_fqn);
            if source_entry != () {
                let source = source_entry.struct_def;
                reverse_navs.push(#{
                    method_name: "find_" + reverse_nav_method_suffix(target, rel.name),
                    target_type: get_cpp_type_from_fqn(target.fqn, target.name),
                    target_key_field: target_pk,
                    source_type: get_cpp_type_from_fqn(source.fqn, source.name),
                    source_member: cpp_types::to_snake_case(pluralize(source.name)),
                    source_method: "get_by_" + cpp_types::to_snake_case(rel.source_field)
                });
            }
        }
    }

    result += "// Main data container with all tables\n";
    result += "class " + container_name + " {\n";
    result += "public:\n";

    for entry in tables {
        let s = entry.struct_def;
        let member_name = cpp_types::to_snake_case(pluralize(s.name));
        result += "    " + s.name + "Table " + member_name + ";\n";
    }

    result += "\n";

    // Clear all method
    result += "    void clear() {\n";
    for entry in tables {
        let s = entry.struct_def;
        let member_name = cpp_types::to_snake_case(pluralize(s.name));
        result += "        " + member_name + ".clear();\n";
    }
    result += "    }\n\n";

    // ValidateAll method
    result += "    /// Validates all tables and returns combined results.\n";
    result += "    polygen::ValidationResult validate_all() const {\n";
    result += "        polygen::ValidationResult result;\n";
    result += "        // Field constraint validation\n";
    for entry in tables {
        let s = entry.struct_def;
        let member_name = cpp_types::to_snake_case(pluralize(s.name));
        result += "        result.merge(" + member_name + ".validate());\n";
    }
    result += "        // Foreign key validation\n";
    for entry in tables {
        let s = entry.struct_def;
        let member_name = cpp_types::to_snake_case(pluralize(s.name));
        result += "        result.merge(" + member_name + ".validate_foreign_keys(*this));\n";
    }
    result += "        return result;\n";
    result += "    }\n\n";

    // ValidateOrThrow method
    result += "    /// Validates all tables and throws if any errors found.\n";
    result += "    void validate_or_throw() const {\n";
    result += "        auto result = validate_all();\n";
    result += "        if (!result.is_valid()) {\n";
    result += "            throw polygen::ValidationException(result);\n";
    result += "        }\n";
    result += "    }\n\n";

    for entry in tables {
        let s = entry.struct_def;
        let member_name = cpp_types::to_snake_case(pluralize(s.name));
        if entry.csv_pattern != "" {
            result += "    void load_" + member_name + "_from_csv(const std::filesystem::path& path) {\n";
            result += "        " + member_name + ".load_all(polygen_loaders::load_" + s.name + "_from_csv_file(path.string()));\n";
            result += "    }\n\n";
        }
        if entry.json_pattern != "" {
            result += "    void load_" + member_name + "_from_json(const std::filesystem::path& path) {\n";
            result += "        " + member_name + ".load_all(polygen_loaders::load_" + s.name + "_from_json_file(path.string()));\n";
            result += "    }\n\n";
        }
    }

    result += "    void load_from_csv(const std::filesystem::path& root) {\n";
    for entry in tables {
        if entry.csv_pattern != "" {
            let s = entry.struct_def;
            let member_name = cpp_types::to_snake_case(pluralize(s.name));
            result += "        load_" + member_name + "_from_csv(root / " + cpp_string_literal(entry.csv_pattern) + ");\n";
        }
    }
    result += "    }\n\n";

    result += "    void load_from_json(const std::filesystem::path& root) {\n";
    for entry in tables {
        if entry.json_pattern != "" {
            let s = entry.struct_def;
            let member_name = cpp_types::to_snake_case(pluralize(s.name));
            result += "        load_" + member_name + "_from_json(root / " + cpp_string_literal(entry.json_pattern) + ");\n";
        }
    }
    result += "    }\n";

    for nav in forward_navs {
        result += "\n";
        result += "    " + nav.target_type + "* " + nav.method_name + "(const " + nav.source_type + "& row) {\n";
        if nav.is_optional {
            result += "        if (!row." + nav.field_name + ".has_value()) {\n";
            result += "            return nullptr;\n";
            result += "        }\n";
            result += "        return " + nav.target_member + "." + nav.target_method + "(row." + nav.field_name + ".value());\n";
        } else {
            result += "        return " + nav.target_member + "." + nav.target_method + "(row." + nav.field_name + ");\n";
        }
        result += "    }\n\n";
        result += "    const " + nav.target_type + "* " + nav.method_name + "(const " + nav.source_type + "& row) const {\n";
        if nav.is_optional {
            result += "        if (!row." + nav.field_name + ".has_value()) {\n";
            result += "            return nullptr;\n";
            result += "        }\n";
            result += "        return " + nav.target_member + "." + nav.target_method + "(row." + nav.field_name + ".value());\n";
        } else {
            result += "        return " + nav.target_member + "." + nav.target_method + "(row." + nav.field_name + ");\n";
        }
        result += "    }\n";
    }

    for nav in reverse_navs {
        result += "\n";
        result += "    std::vector<" + nav.source_type + "*> " + nav.method_name + "(" + nav.target_type + "& row) {\n";
        result += "        const auto& rows = " + nav.source_member + "." + nav.source_method + "(row." + nav.target_key_field + ");\n";
        result += "        return std::vector<" + nav.source_type + "*>(rows.begin(), rows.end());\n";
        result += "    }\n\n";
        result += "    std::vector<const " + nav.source_type + "*> " + nav.method_name + "(const " + nav.target_type + "& row) const {\n";
        result += "        const auto& rows = " + nav.source_member + "." + nav.source_method + "(row." + nav.target_key_field + ");\n";
        result += "        std::vector<const " + nav.source_type + "*> result;\n";
        result += "        result.reserve(rows.size());\n";
        result += "        for (const auto* item : rows) {\n";
        result += "            result.push_back(item);\n";
        result += "        }\n";
        result += "        return result;\n";
        result += "    }\n";
    }

    result += "};\n";

    return result;
}

fn collect_indexed_tables_from_namespace(ns) {
    let tables = [];

    for item in ns.items {
        if item.is_struct() {
            let s = item.as_struct();
            if has_indexes(s) {
                tables.push(#{
                    struct_def: s,
                    namespace_name: ns.name,
                    csv_pattern: get_load_pattern(s, "csv"),
                    json_pattern: get_load_pattern(s, "json")
                });
            }
        } else if item.is_namespace() {
            let child_tables = collect_indexed_tables_from_namespace(item.as_namespace());
            for child_table in child_tables {
                tables.push(child_table);
            }
        }
    }

    tables
}

// ============================================================
// Data preparation
// ============================================================

// Guard: per_file template needs file.path
let has_file = file.path != () && file.path != "";

// Extract base_name
let base_name = "";
if has_file {
    let parts = file.path.split("/");
    let filename = parts[parts.len - 1];
    base_name = filename + "";
    base_name.replace(".poly", "");
}

// Collect all tables (structs with indexes)
let tables = [];
if has_file {
    for ns in file.namespaces {
        let ns_tables = collect_indexed_tables_from_namespace(ns);
        for table in ns_tables {
            tables.push(table);
        }
    }
}

let has_tables = tables.len() > 0;

// Pre-compute per-table wrapper bodies
let idx = 0;
for entry in tables {
    let s = entry.struct_def;
    let ns = entry.namespace_name;
    tables[idx].wrapper_body = generate_table_wrapper(s, ns);
    idx += 1;
}

// Pre-compute container body
let container_body = "";
let container_ns = "";
if has_tables {
    container_body = generate_container(base_name, tables);
    container_ns = base_name + "";
    container_ns.replace("-", "_");
    container_ns += "_container";
}
%endlogic
