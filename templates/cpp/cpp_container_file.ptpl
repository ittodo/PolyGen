namespace detail {
inline std::string search_normalize(const std::string& value, const std::string& policy) {
    auto begin = value.begin();
    auto end = value.end();
    if (policy == "trim" || policy == "lower_trim") {
        begin = std::find_if_not(begin, end, [](unsigned char ch) { return std::isspace(ch); });
        end = std::find_if_not(value.rbegin(), std::make_reverse_iterator(begin), [](unsigned char ch) { return std::isspace(ch); }).base();
    }

    std::string result(begin, end);
    if (policy == "lower" || policy == "lower_trim") {
        std::transform(result.begin(), result.end(), result.begin(), [](unsigned char ch) {
            return static_cast<char>(std::tolower(ch));
        });
    }
    return result;
}

inline std::vector<std::string> search_tokens(const std::string& value, const std::string& mode, size_t n, size_t min, const std::string& normalize_policy) {
    const auto normalized = search_normalize(value, normalize_policy);
    if (normalized.size() < min) {
        return {};
    }

    std::unordered_set<std::string> seen;
    std::vector<std::string> result;

    if (mode == "word") {
        std::istringstream input(normalized);
        std::string token;
        while (input >> token) {
            if (token.size() >= min && seen.insert(token).second) {
                result.push_back(token);
            }
        }
        return result;
    }

    if (normalized.size() < n) {
        return {};
    }

    for (size_t i = 0; i + n <= normalized.size(); ++i) {
        auto token = normalized.substr(i, n);
        if (seen.insert(token).second) {
            result.push_back(std::move(token));
        }
    }
    return result;
}

template<typename T>
std::vector<T*> copy_search_results(const std::vector<T*>& rows) {
    return rows;
}

template<typename T>
std::vector<T*> search_intersect(
    const std::unordered_map<std::string, std::vector<T*>>& index,
    const std::string& query,
    const std::string& mode,
    size_t n,
    size_t min,
    const std::string& normalize_policy) {
    const auto tokens = search_tokens(query, mode, n, min, normalize_policy);
    if (tokens.empty()) {
        return {};
    }

    auto first = index.find(tokens.front());
    if (first == index.end()) {
        return {};
    }

    std::vector<T*> matches = first->second;
    for (size_t i = 1; i < tokens.size(); ++i) {
        auto next = index.find(tokens[i]);
        if (next == index.end()) {
            return {};
        }
        std::unordered_set<T*> next_set(next->second.begin(), next->second.end());
        matches.erase(std::remove_if(matches.begin(), matches.end(), [&](T* row) {
            return next_set.find(row) == next_set.end();
        }), matches.end());
        if (matches.empty()) {
            return {};
        }
    }
    return matches;
}
