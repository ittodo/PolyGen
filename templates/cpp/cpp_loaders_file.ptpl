%for entry in all_structs
{{entry.json_fwd}}
{{entry.csv_fwd}}
%endfor
%blank
%for entry in all_structs
{{entry.json_body}}
%blank
{{entry.csv_body}}
%blank
{{entry.csv_load_body}}
%blank
{{entry.json_load_body}}
%blank
%endfor
// ============================================================================
// Binary Readers
// ============================================================================
%blank
%for entry in all_structs
{{entry.read_fwd}}
%endfor
%blank
%for entry in all_structs
{{entry.read_body}}
%blank
%endfor
// ============================================================================
// Binary Writers
// ============================================================================
%blank
%for entry in all_structs
{{entry.write_fwd}}
%endfor
%blank
%for entry in all_structs
{{entry.write_body}}
%blank
%endfor
} // namespace polygen_loaders
%endif
