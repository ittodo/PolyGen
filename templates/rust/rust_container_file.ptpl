    mod container_search {
        use std::collections::{HashMap, HashSet};

        pub fn normalize(value: &str, policy: &str) -> String {
            match policy {
                "lower" => value.to_lowercase(),
                "trim" => value.trim().to_string(),
                "lower_trim" => value.trim().to_lowercase(),
                _ => value.to_string(),
            }
        }

        pub fn tokens(value: &str, mode: &str, n: usize, min: usize, normalize_policy: &str) -> Vec<String> {
            let value = normalize(value, normalize_policy);
            if value.len() < min {
                return Vec::new();
            }

            let mut seen = HashSet::new();
            let mut result = Vec::new();

            if mode == "word" {
                for token in value.split_whitespace() {
                    let token = token.to_string();
                    if token.len() >= min && seen.insert(token.clone()) {
                        result.push(token);
                    }
                }
                return result;
            }

            let chars: Vec<char> = value.chars().collect();
            if chars.len() < n {
                return Vec::new();
            }

            for i in 0..=(chars.len() - n) {
                let token: String = chars[i..i + n].iter().collect();
                if seen.insert(token.clone()) {
                    result.push(token);
                }
            }
            result
        }

        pub fn add(index: &mut HashMap<String, Vec<usize>>, key: String, row_index: usize) {
            index.entry(key).or_default().push(row_index);
        }

        pub fn search<'a, T>(
            index: &HashMap<String, Vec<usize>>,
            rows: &'a [T],
            query: &str,
            mode: &str,
            n: usize,
            min: usize,
            normalize_policy: &str,
        ) -> Vec<&'a T> {
            let query_tokens = tokens(query, mode, n, min, normalize_policy);
            if query_tokens.is_empty() {
                return Vec::new();
            }

            let mut iter = query_tokens.iter();
            let Some(first) = iter.next() else {
                return Vec::new();
            };
            let Some(first_postings) = index.get(first) else {
                return Vec::new();
            };

            let mut matches: Vec<usize> = first_postings.clone();
            for token in iter {
                let Some(postings) = index.get(token) else {
                    return Vec::new();
                };
                let set: HashSet<usize> = postings.iter().copied().collect();
                matches.retain(|idx| set.contains(idx));
                if matches.is_empty() {
                    return Vec::new();
                }
            }

            matches.into_iter().map(|idx| &rows[idx]).collect()
        }
    }
