%logic
// Rust Container file generator (PolyTemplate)
// Generates Container module with DataTables, indexes, and relations

import "templates/rust/rhai_utils/type_mapping" as rust_types;

fn join_with(arr, sep) {
    let result = "";
    let i = 0;
    for item in arr {
        if i > 0 { result += sep; }
        result += item;
        i += 1;
    }
    result
}

fn find_pk_field(struct_def) {
    // Find primary key field: check is_primary_key first, then fallback to first unique index
    for item in struct_def.items {
        if item.is_field() {
            let f = item.as_field();
            if f.is_primary_key {
                return to_snake_case(f.name);
            }
        }
    }
    for idx in struct_def.indexes {
        if idx.is_unique {
            return to_snake_case(idx.field_name);
        }
    }
    return "";
}

fn search_base_type(t) {
    return t;
}

fn search_type_name_to_rust(type_name) {
    switch type_name {
        "string" => "String",
        "bool" => "bool",
        "bytes" => "Vec<u8>",
        "u8" => "u8",
        "u16" => "u16",
        "u32" => "u32",
        "u64" => "u64",
        "i8" => "i8",
        "i16" => "i16",
        "i32" => "i32",
        "i64" => "i64",
        "timestamp" => "chrono::DateTime<chrono::Utc>",
        _ => type_name
    }
}

fn search_is_string(f) {
    return search_base_type(f.field_type).type_name == "string";
}

fn search_is_supported(f) {
    if !f.has_search_index {
        return false;
    }
    let search = f.search_index;
    if search.target != "csharp" && search.target != "rust" && search.target != "rust_container" {
        return false;
    }
    let base = search_base_type(f.field_type);
    if search.mode == "ngram" || search.mode == "word" {
        return base.type_name == "string";
    }
    return search.mode == "exact";
}

fn search_key_type(f, schema_mod) {
    let search = f.search_index;
    if search.mode == "ngram" || search.mode == "word" {
        return "String";
    }

    let base = search_base_type(f.field_type);
    if base.type_name == "string" {
        return "String";
    }
    if !base.is_primitive && base.namespace_fqn != "" {
        return "crate::" + schema_mod + "::" + rust_types::ns_to_module_name(base.namespace_fqn) + "::" + base.type_name;
    }
    return search_type_name_to_rust(base.type_name);
}

fn search_method_param(f, key_type) {
    let search = f.search_index;
    if search.mode == "ngram" || search.mode == "word" || search_is_string(f) {
        return "query: &str";
    }
    return "key: " + key_type;
}

fn container_index_key_type(index, schema_mod) {
    if index.is_composite {
        let result = "(";
        for i in 0..index.fields.len() {
            if i > 0 { result += ", "; }
            result += container_key_type(index.fields[i].field_type, schema_mod);
        }
        result += ")";
        return result;
    }
    return container_key_type(index.field_type, schema_mod);
}

fn container_key_type(type_ref, schema_mod) {
    if type_ref.is_primitive || rust_types::is_primitive_name(type_ref.type_name) {
        return rust_types::map_type(type_ref);
    }
    if type_ref.namespace_fqn != "" {
        return "crate::" + schema_mod + "::" + rust_types::ns_to_module_name(type_ref.namespace_fqn) + "::" + type_ref.type_name;
    }
    return type_ref.type_name;
}

fn container_index_key_expr(index, row_var) {
    if index.is_composite {
        let result = "(";
        for i in 0..index.fields.len() {
            if i > 0 { result += ", "; }
            result += row_var + "." + to_snake_case(index.fields[i].name) + ".clone()";
        }
        result += ")";
        return result;
    }

    let field_name = to_snake_case(index.field_name);
    if index.field_type.type_name == "string" {
        return row_var + "." + field_name + ".clone()";
    }
    return row_var + "." + field_name;
}

fn collect_struct_entries_from_namespace(ns, schema_mod, namespace_path) {
    let entries = [];

    for item in ns.items {
        if item.is_struct() {
            let s = item.as_struct();
            if !s.name.ends_with("__Enum") {
                let csv_pattern = "";
                let json_pattern = "";
                if s.load != () {
                    if s.load.csv != () {
                        csv_pattern = s.load.csv;
                    }
                    if s.load.json != () {
                        json_pattern = s.load.json;
                    }
                }
                entries.push(#{
                    name: s.name,
                    path: "crate::" + schema_mod + "::" + namespace_path + "::" + s.name,
                    table_name: to_snake_case(s.name) + "s",
                    namespace_path: namespace_path,
                    def: s,
                    csv_pattern: csv_pattern,
                    json_pattern: json_pattern
                });
            }
        } else if item.is_namespace() {
            let child = item.as_namespace();
            let child_path = namespace_path + "::" + rust_types::ns_to_module_name(child.name);
            let child_entries = collect_struct_entries_from_namespace(child, schema_mod, child_path);
            for child_entry in child_entries {
                entries.push(child_entry);
            }
        }
    }

    entries
}

fn find_table_entry_by_fqn(entries, fqn) {
    for entry in entries {
        if entry.def.fqn == fqn {
            return entry;
        }
    }
    ()
}

fn nav_field_label(field_name) {
    let label = to_snake_case(field_name);
    if label.ends_with("_id") && label.len() > 3 {
        return label.sub_string(0, label.len() - 3);
    }
    label
}

fn nav_method_suffix(source_table, field_name) {
    to_snake_case(source_table.name) + "_" + nav_field_label(field_name)
}

fn reverse_nav_method_suffix(target_table, relation_name) {
    to_snake_case(target_table.name) + "_" + to_snake_case(relation_name)
}

let skip_file = file.path == () || file.path == "";

let schema_mod = "";
let container_name = "";
let all_tables = [];
let structs_with_relations = [];
let has_relations = false;
let relations_body = "";
let forward_navs = [];
let reverse_navs = [];
let has_unique_index = false;

if !skip_file {
    let parts = file.path.split("/");
    let filename = parts[parts.len - 1];

    schema_mod = filename;
    schema_mod.replace(".poly", "");

    let last_part = filename;
    last_part.replace(".poly", "");
    container_name = to_pascal_case(last_part) + "Container";

    // Collect all tables
    for ns in file.namespaces {
        let ns_mod_path = rust_types::ns_to_module_name(ns.name);
        let entries = collect_struct_entries_from_namespace(ns, schema_mod, ns_mod_path);
        for entry in entries {
            all_tables.push(entry);
        }
    }

    // Pre-compute per-table bodies (must use index to mutate)
    let tidx = 0;
    for table in all_tables {
        let struct_def = table.def;
        let table_type = table.name + "Table";
        let pk_field = find_pk_field(struct_def);

        // Index struct fields
        let idx_field_lines = [];
        for idx in struct_def.indexes {
            let idx_field = to_snake_case(idx.name);
            let key_type = container_index_key_type(idx, schema_mod);
            if idx.is_unique {
                has_unique_index = true;
                idx_field_lines.push("        " + idx_field + ": UniqueIndex<" + key_type + ", usize>,");
            } else {
                idx_field_lines.push("        " + idx_field + ": GroupIndex<" + key_type + ">,");
            }
        }
        all_tables[tidx].idx_fields_body = join_with(idx_field_lines, "\n");

        // Search index struct fields
        let search_indexes = [];
        for item in struct_def.items {
            if item.is_field() {
                let field = item.as_field();
                if search_is_supported(field) {
                    let search = field.search_index;
                    let key_type = search_key_type(field, schema_mod);
                    search_indexes.push(#{
                        name: search.name,
                        method_name: "search_by_" + to_snake_case(search.name),
                        field_name: to_snake_case(field.name),
                        var_name: "search_" + to_snake_case(search.name),
                        key_type: key_type,
                        method_param: search_method_param(field, key_type),
                        mode: search.mode,
                        n: search.n,
                        min: search.min,
                        normalize: search.normalize,
                        is_token_mode: search.mode == "ngram" || search.mode == "word",
                        is_string: search_is_string(field),
                        is_option: field.field_type.is_option
                    });
                }
            }
        }
        all_tables[tidx].search_indexes = search_indexes;

        let search_field_lines = [];
        for search in search_indexes {
            if search.is_token_mode {
                search_field_lines.push("        " + search.var_name + ": HashMap<String, Vec<usize>>," );
            } else {
                search_field_lines.push("        " + search.var_name + ": GroupIndex<" + search.key_type + ">," );
            }
        }
        all_tables[tidx].search_fields_body = join_with(search_field_lines, "\n");

        // Getter methods
        let getter_lines = [];
        for idx in struct_def.indexes {
            let method_name = "get_" + to_snake_case(idx.name);
            let idx_field = to_snake_case(idx.name);
            let key_type = container_index_key_type(idx, schema_mod);

            if idx.is_unique {
                getter_lines.push("        /// Get by " + idx.field_name + " (unique)");
                getter_lines.push("        pub fn " + method_name + "(&self, key: " + key_type + ") -> Option<&" + table.path + "> {");
                getter_lines.push("            self." + idx_field + ".get(&key).map(|&idx| &self.rows[idx])");
                getter_lines.push("        }");
                getter_lines.push("");
            } else {
                getter_lines.push("        /// Get by " + idx.field_name + " (group)");
                getter_lines.push("        pub fn " + method_name + "(&self, key: " + key_type + ") -> Vec<&" + table.path + "> {");
                getter_lines.push("            self." + idx_field + ".get(&key).iter().map(|&idx| &self.rows[idx]).collect()");
                getter_lines.push("        }");
                getter_lines.push("");
            }
        }
        all_tables[tidx].getter_body = join_with(getter_lines, "\n");

        // Search methods
        let search_getter_lines = [];
        for search in search_indexes {
            search_getter_lines.push("        /// Search by " + search.name);
            search_getter_lines.push("        pub fn " + search.method_name + "(&self, " + search.method_param + ") -> Vec<&" + table.path + "> {");
            if search.is_token_mode {
                search_getter_lines.push("            container_search::search(&self." + search.var_name + ", &self.rows, query, \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\")");
            } else if search.is_string {
                search_getter_lines.push("            let key = container_search::normalize(query, \"" + search.normalize + "\");");
                search_getter_lines.push("            self." + search.var_name + ".get(&key).iter().map(|&idx| &self.rows[idx]).collect()");
            } else {
                search_getter_lines.push("            self." + search.var_name + ".get(&key).iter().map(|&idx| &self.rows[idx]).collect()");
            }
            search_getter_lines.push("        }");
            search_getter_lines.push("");
        }
        all_tables[tidx].search_getter_body = join_with(search_getter_lines, "\n");

        // add_row index lines
        let add_row_lines = [];
        for idx in struct_def.indexes {
            let idx_field = to_snake_case(idx.name);
            let key_expr = container_index_key_expr(idx, "row");
            if idx.is_unique {
                add_row_lines.push("            self." + idx_field + ".insert(" + key_expr + ", idx);");
            } else {
                add_row_lines.push("            self." + idx_field + ".add(" + key_expr + ", idx);");
            }
        }
        all_tables[tidx].add_row_body = join_with(add_row_lines, "\n");

        // add_row search index lines
        let add_search_lines = [];
        for search in search_indexes {
            if search.is_token_mode {
                if search.is_option {
                    add_search_lines.push("            if let Some(value) = &row." + search.field_name + " {");
                    add_search_lines.push("                for token in container_search::tokens(value, \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\") {");
                    add_search_lines.push("                    container_search::add(&mut self." + search.var_name + ", token, idx);");
                    add_search_lines.push("                }");
                    add_search_lines.push("            }");
                } else {
                    add_search_lines.push("            for token in container_search::tokens(&row." + search.field_name + ", \"" + search.mode + "\", " + search.n + ", " + search.min + ", \"" + search.normalize + "\") {");
                    add_search_lines.push("                container_search::add(&mut self." + search.var_name + ", token, idx);");
                    add_search_lines.push("            }");
                }
            } else if search.is_string {
                if search.is_option {
                    add_search_lines.push("            if let Some(value) = &row." + search.field_name + " {");
                    add_search_lines.push("                self." + search.var_name + ".add(container_search::normalize(value, \"" + search.normalize + "\"), idx);");
                    add_search_lines.push("            }");
                } else {
                    add_search_lines.push("            self." + search.var_name + ".add(container_search::normalize(&row." + search.field_name + ", \"" + search.normalize + "\"), idx);");
                }
            } else {
                if search.is_option {
                    add_search_lines.push("            if let Some(value) = row." + search.field_name + ".clone() {");
                    add_search_lines.push("                self." + search.var_name + ".add(value, idx);");
                    add_search_lines.push("            }");
                } else {
                    add_search_lines.push("            self." + search.var_name + ".add(row." + search.field_name + ".clone(), idx);");
                }
            }
        }
        all_tables[tidx].add_search_body = join_with(add_search_lines, "\n");

        // clear index lines
        let clear_lines = [];
        for idx in struct_def.indexes {
            let idx_field = to_snake_case(idx.name);
            clear_lines.push("            self." + idx_field + ".clear();");
        }
        for search in search_indexes {
            clear_lines.push("            self." + search.var_name + ".clear();");
        }
        all_tables[tidx].clear_body = join_with(clear_lines, "\n");

        // validate body
        let validate_lines = [];
        if pk_field != "" {
            validate_lines.push("            for row in &self.rows {");
            validate_lines.push("                let row_key = row." + pk_field + ".to_string();");
        } else {
            validate_lines.push("            for (row_idx, row) in self.rows.iter().enumerate() {");
            validate_lines.push("                let row_key = row_idx.to_string();");
        }

        for item in struct_def.items {
            if item.is_field() {
                let field = item.as_field();
                let field_name = to_snake_case(field.name);
                let is_option = field.field_type.is_option;
                let type_name = field.field_type.type_name;

                if field.max_length != () {
                    let max_len = field.max_length;
                    if is_option {
                        validate_lines.push("                if let Some(ref v) = row." + field_name + " {");
                        validate_lines.push("                    if v.len() > " + max_len + " {");
                        validate_lines.push("                        result.add_error(validation::max_length_error(");
                        validate_lines.push("                            \"" + table.name + "\", \"" + field_name + "\", &row_key, " + max_len + ", v.len()));");
                        validate_lines.push("                    }");
                        validate_lines.push("                }");
                    } else if type_name == "string" {
                        validate_lines.push("                if row." + field_name + ".len() > " + max_len + " {");
                        validate_lines.push("                    result.add_error(validation::max_length_error(");
                        validate_lines.push("                        \"" + table.name + "\", \"" + field_name + "\", &row_key, " + max_len + ", row." + field_name + ".len()));");
                        validate_lines.push("                }");
                    }
                }

                if field.range != () {
                    let min_val = field.range.min;
                    let max_val = field.range.max;
                    if is_option {
                        validate_lines.push("                if let Some(v) = row." + field_name + " {");
                        validate_lines.push("                    if !validation::validate_range(v, " + min_val + ", " + max_val + ") {");
                        validate_lines.push("                        result.add_error(validation::range_error(");
                        validate_lines.push("                            \"" + table.name + "\", \"" + field_name + "\", &row_key, " + min_val + ", " + max_val + ", v));");
                        validate_lines.push("                    }");
                        validate_lines.push("                }");
                    } else {
                        validate_lines.push("                if !validation::validate_range(row." + field_name + ", " + min_val + ", " + max_val + ") {");
                        validate_lines.push("                    result.add_error(validation::range_error(");
                        validate_lines.push("                        \"" + table.name + "\", \"" + field_name + "\", &row_key, " + min_val + ", " + max_val + ", row." + field_name + "));");
                        validate_lines.push("                }");
                    }
                }

                if field.regex_pattern != () {
                    let pattern = field.regex_pattern;
                    if is_option {
                        validate_lines.push("                if let Some(ref v) = row." + field_name + " {");
                        validate_lines.push("                    if !validation::validate_regex(v, r\"" + pattern + "\") {");
                        validate_lines.push("                        result.add_error(validation::regex_error(");
                        validate_lines.push("                            \"" + table.name + "\", \"" + field_name + "\", &row_key, r\"" + pattern + "\", v));");
                        validate_lines.push("                    }");
                        validate_lines.push("                }");
                    } else if type_name == "string" {
                        validate_lines.push("                if !validation::validate_regex(&row." + field_name + ", r\"" + pattern + "\") {");
                        validate_lines.push("                    result.add_error(validation::regex_error(");
                        validate_lines.push("                        \"" + table.name + "\", \"" + field_name + "\", &row_key, r\"" + pattern + "\", &row." + field_name + "));");
                        validate_lines.push("                }");
                    }
                }
            }
        }

        validate_lines.push("            }");

        for idx in struct_def.indexes {
            if idx.is_unique {
                let seen_name = "seen_" + to_snake_case(idx.name);
                let key_expr = container_index_key_expr(idx, "row");
                validate_lines.push("            let mut " + seen_name + " = HashSet::new();");
                if pk_field != "" {
                    validate_lines.push("            for row in self.rows.iter() {");
                    validate_lines.push("                let row_key = row." + pk_field + ".to_string();");
                } else {
                    validate_lines.push("            for (row_idx, row) in self.rows.iter().enumerate() {");
                    validate_lines.push("                let row_key = row_idx.to_string();");
                }
                validate_lines.push("                let key = " + key_expr + ";");
                validate_lines.push("                if !" + seen_name + ".insert(key.clone()) {");
                validate_lines.push("                    result.add_error(validation::unique_error(");
                validate_lines.push("                        \"" + table.name + "\", \"" + idx.name + "\", &row_key, format!(\"{:?}\", key)));");
                validate_lines.push("                }");
                validate_lines.push("            }");
            }
        }
        validate_lines.push("            result");
        all_tables[tidx].validate_body = join_with(validate_lines, "\n");

        // validate_foreign_keys body
        let fk_lines = [];
        let has_fk = false;
        for item in struct_def.items {
            if item.is_field() {
                let field = item.as_field();
                if field.foreign_key != () {
                    has_fk = true;
                }
            }
        }
        all_tables[tidx].has_fk = has_fk;

        if !has_fk {
            fk_lines.push("            let _ = container; // Suppress unused variable warning");
        } else {
            if pk_field != "" {
                fk_lines.push("            for row in &self.rows {");
                fk_lines.push("                let row_key = row." + pk_field + ".to_string();");
            } else {
                fk_lines.push("            for (row_idx, row) in self.rows.iter().enumerate() {");
                fk_lines.push("                let row_key = row_idx.to_string();");
            }

            for item in struct_def.items {
                if item.is_field() {
                    let field = item.as_field();
                    if field.foreign_key != () {
                        let fk = field.foreign_key;
                        let field_name = to_snake_case(field.name);
                        let target_parts = fk.target_table_fqn.split(".");
                        let target_table = "";
                        for part in target_parts {
                            target_table = part;
                        }
                        let target_member = to_snake_case(target_table) + "s";
                        let target_getter = "get_by_" + to_snake_case(fk.target_field);

                        if field.field_type.is_option {
                            fk_lines.push("                if let Some(fk_value) = row." + field_name + " {");
                            fk_lines.push("                    if container." + target_member + "." + target_getter + "(fk_value).is_none() {");
                            fk_lines.push("                        result.add_error(validation::foreign_key_error(");
                            fk_lines.push("                            \"" + table.name + "\", \"" + field_name + "\", &row_key,");
                            fk_lines.push("                            \"" + target_table + "\", &fk_value.to_string()));");
                            fk_lines.push("                    }");
                            fk_lines.push("                }");
                        } else {
                            fk_lines.push("                if container." + target_member + "." + target_getter + "(row." + field_name + ").is_none() {");
                            fk_lines.push("                    result.add_error(validation::foreign_key_error(");
                            fk_lines.push("                        \"" + table.name + "\", \"" + field_name + "\", &row_key,");
                            fk_lines.push("                        \"" + target_table + "\", &row." + field_name + ".to_string()));");
                            fk_lines.push("                }");
                        }
                    }
                }
            }
            fk_lines.push("            }");
        }
        fk_lines.push("            result");
        all_tables[tidx].fk_body = join_with(fk_lines, "\n");

        all_tables[tidx].table_type = table_type;
        all_tables[tidx].pk_field = pk_field;

        tidx += 1;
    }

    // Collect structs with relations
    for ns in file.namespaces {
        let ns_mod_path2 = rust_types::ns_to_module_name(ns.name);
        let entries = collect_struct_entries_from_namespace(ns, schema_mod, ns_mod_path2);
        for entry in entries {
            let s = entry.def;
            if s.relations.len() > 0 {
                structs_with_relations.push(#{
                    name: entry.name,
                    path: entry.path,
                    def: s
                });
            }
        }
    }

    // Root container FK navigation helper metadata
    for table in all_tables {
        let struct_def = table.def;
        for item in struct_def.items {
            if item.is_field() {
                let field = item.as_field();
                if field.foreign_key != () {
                    let fk = field.foreign_key;
                    let target_table = find_table_entry_by_fqn(all_tables, fk.target_table_fqn);
                    if target_table != () {
                        forward_navs.push(#{
                            method_name: "get_" + nav_method_suffix(struct_def, field.name),
                            source_path: table.path,
                            field_name: to_snake_case(field.name),
                            target_path: target_table.path,
                            target_member: target_table.table_name,
                            target_method: "get_by_" + to_snake_case(fk.target_field),
                            is_optional: field.field_type.is_option
                        });
                    }
                }
            }
        }
    }

    for table in all_tables {
        let struct_def = table.def;
        for rel in struct_def.relations {
            let source_table = find_table_entry_by_fqn(all_tables, rel.source_table_fqn);
            if source_table != () {
                let pk_field = find_pk_field(struct_def);
                if pk_field == "" { pk_field = "id"; }
                reverse_navs.push(#{
                    method_name: "find_" + reverse_nav_method_suffix(struct_def, rel.name),
                    target_path: table.path,
                    target_key_field: pk_field,
                    source_path: source_table.path,
                    source_member: source_table.table_name,
                    source_method: "get_by_" + to_snake_case(rel.source_field)
                });
            }
        }
    }

    has_relations = structs_with_relations.len() > 0;

    // Pre-compute relations body
    if has_relations {
        let rel_lines = [];
        rel_lines.push("pub mod relations {");
        rel_lines.push("    //! Relation methods for navigating between tables");
        rel_lines.push("");
        rel_lines.push("    use super::container::" + container_name + ";");
        rel_lines.push("");

        for s in structs_with_relations {
            let struct_def = s.def;
            rel_lines.push("    /// Relation methods for " + s.name);
            rel_lines.push("    impl " + s.path + " {");

            for rel in struct_def.relations {
                let method_name = to_snake_case(rel.name);
                let source_table = to_snake_case(rel.source_table_name) + "s";
                let source_field = to_snake_case(rel.source_field);
                let rel_pk = find_pk_field(struct_def);
                if rel_pk == "" { rel_pk = "id"; }

                let fqn = rel.source_table_fqn;
                let type_suffix = "." + rel.source_table_name;
                let ns_fqn = fqn;
                if fqn.ends_with(type_suffix) {
                    ns_fqn = fqn.sub_string(0, fqn.len() - type_suffix.len());
                }
                let rel_ns_path = ns_fqn;
                rel_ns_path.replace(".", "_");

                rel_lines.push("        /// Get related " + rel.name);
                rel_lines.push("        pub fn " + method_name + "<'a>(&self, container: &'a " + container_name + ") -> Vec<&'a crate::" + schema_mod + "::" + rel_ns_path + "::" + rel.source_table_name + "> {");
                rel_lines.push("            container." + source_table + ".get_by_" + source_field + "(self." + rel_pk + ")");
                rel_lines.push("        }");
                rel_lines.push("");
            }
            rel_lines.push("    }");
            rel_lines.push("");
        }
        rel_lines.push("}");
        relations_body = join_with(rel_lines, "\n");
    }
}
