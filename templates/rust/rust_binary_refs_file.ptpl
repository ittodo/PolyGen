fn rows_for_key<'a, K, R>(index: &HashMap<K, Vec<usize>>, rows: &'a [R], key: &K) -> Vec<&'a R>
where
    K: Eq + std::hash::Hash,
{
    index
        .get(key)
        .map(|indices| indices.iter().filter_map(|idx| rows.get(*idx)).collect())
        .unwrap_or_default()
}
%blank
fn rows_for_tokens<'a, R>(
    index: &HashMap<String, Vec<usize>>,
    rows: &'a [R],
    tokens: Vec<String>,
) -> Vec<&'a R> {
    if tokens.is_empty() {
        return Vec::new();
    }
    let mut iter = tokens.iter();
    let Some(first) = iter.next() else {
        return Vec::new();
    };
    let Some(first_postings) = index.get(first) else {
        return Vec::new();
    };
    let mut matches = first_postings.clone();
    for token in iter {
        let Some(postings) = index.get(token) else {
            return Vec::new();
        };
        let set: HashSet<usize> = postings.iter().copied().collect();
        matches.retain(|idx| set.contains(idx));
    }
    matches.into_iter().filter_map(|idx| rows.get(idx)).collect()
}
