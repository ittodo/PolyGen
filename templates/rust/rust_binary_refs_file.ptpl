%logic
// Rust BinaryRef generator.
// Generates indexed row refs backed by a shared binary document.

import "templates/rust/rhai_utils/type_mapping" as rust_types;

fn to_pascal(name) {
    let result = "";
    let capitalize_next = true;
    for i in 0..name.len() {
        let c = name.sub_string(i, 1);
        if c == "_" || c == "-" || c == "." {
            capitalize_next = true;
        } else if capitalize_next {
            result += c.to_upper();
            capitalize_next = false;
        } else {
            result += c;
        }
    }
    result
}

fn pluralize(name) {
    if name.ends_with("y") {
        return name.sub_string(0, name.len() - 1) + "ies";
    } else if name.ends_with("s") || name.ends_with("x") || name.ends_with("ch") || name.ends_with("sh") {
        return name + "es";
    }
    return name + "s";
}

fn namespace_path(ns_fqn) {
    if ns_fqn == "" {
        return "";
    }
    return rust_types::ns_to_module_name(ns_fqn);
}

fn type_path(t) {
    if t.is_primitive || rust_types::is_primitive_name(t.type_name) {
        return rust_types::map_primitive(t.type_name);
    }
    let ns_path = namespace_path(t.namespace_fqn);
    if ns_path == "" {
        return "crate::schema::" + t.type_name;
    }
    return "crate::schema::" + ns_path + "::" + t.type_name;
}

fn key_type(t) {
    let base = if t.is_option { t.inner } else { t };
    return type_path(base);
}

fn can_index_type(t) {
    if t.is_option || t.is_list {
        return false;
    }
    if t.type_name == "bytes" {
        return false;
    }
    return true;
}

fn can_index(idx) {
    if idx.is_composite {
        for field in idx.fields {
            if !can_index_type(field.field_type) {
                return false;
            }
        }
        return true;
    }
    return can_index_type(idx.field_type);
}

fn index_key_type(idx) {
    if idx.is_composite {
        let result = "(";
        for i in 0..idx.fields.len() {
            if i > 0 { result += ", "; }
            result += key_type(idx.fields[i].field_type);
        }
        result += ")";
        return result;
    }
    return key_type(idx.field_type);
}

fn index_key_expr(idx) {
    if idx.is_composite {
        let result = "(";
        for i in 0..idx.fields.len() {
            if i > 0 { result += ", "; }
            result += "row." + idx.fields[i].name + ".clone()";
        }
        result += ")";
        return result;
    }
    return "row." + idx.field_name + ".clone()";
}

fn search_target_enabled(search) {
    return search.target == "csharp" || search.target == "rust" || search.target == "rust_binary_ref";
}

fn search_base_type(t) {
    if t.is_option {
        return t.inner;
    }
    return t;
}

fn can_search(field) {
    if !field.has_search_index {
        return false;
    }
    let search = field.search_index;
    if !search_target_enabled(search) {
        return false;
    }
    if field.field_type.is_list {
        return false;
    }
    let base = search_base_type(field.field_type);
    if base.type_name == "bytes" || base.is_struct {
        return false;
    }
    if search.mode == "ngram" || search.mode == "word" {
        return base.type_name == "string";
    }
    return search.mode == "exact";
}

fn can_getter(field_type, owner_struct) {
    if field_type.is_option || field_type.is_list || field_type.is_struct || field_type.is_enum {
        return false;
    }
    return true;
}

fn search_key_type(field) {
    let search = field.search_index;
    if search.mode == "ngram" || search.mode == "word" {
        return "String";
    }
    return key_type(field.field_type);
}

fn search_key_expr(field) {
    let search = field.search_index;
    let base = search_base_type(field.field_type);
    if base.type_name == "string" {
        if field.field_type.is_option {
            return "normalize_string(value, \"" + search.normalize + "\")";
        }
        return "normalize_string(&row." + field.name + ", \"" + search.normalize + "\")";
    }
    return "row." + field.name + ".clone()";
}

fn search_query_arg(field) {
    let search = field.search_index;
    let base = search_base_type(field.field_type);
    if search.mode == "ngram" || search.mode == "word" || base.type_name == "string" {
        return "&str";
    }
    return key_type(field.field_type);
}

fn search_query_expr(field) {
    let search = field.search_index;
    let base = search_base_type(field.field_type);
    if base.type_name == "string" {
        return "normalize_string(query, \"" + search.normalize + "\")";
    }
    return "query";
}

fn collect_structs_from_namespace(ns, namespace_path_value) {
    let entries = [];

    for item in ns.items {
        if item.is_struct() {
            let s = item.as_struct();
            if !s.is_embed {
                let rust_path = if namespace_path_value == "" {
                    "crate::schema::" + s.name
                } else {
                    "crate::schema::" + namespace_path_value + "::" + s.name
                };
                entries.push(#{ def: s, rust_path: rust_path });
            }
        } else if item.is_namespace() {
            let child = item.as_namespace();
            let child_path = if namespace_path_value == "" {
                rust_types::ns_to_module_name(child.name)
            } else {
                namespace_path_value + "::" + rust_types::ns_to_module_name(child.name)
            };
            let child_entries = collect_structs_from_namespace(child, child_path);
            for entry in child_entries {
                entries.push(entry);
            }
        }
    }

    entries
}

fn table_entry(entry) {
    let s = entry.def;
    let safe = to_pascal(s.fqn);
    let indexes = [];
    let searches = [];
    let fields = [];

    for item in s.items {
        if item.is_field() {
            let f = item.as_field();
            if can_getter(f.field_type, s) {
                fields.push(#{
                    name: f.name,
                    method_name: to_snake_case(f.name),
                    type_name: key_type(f.field_type)
                });
            }
            if can_search(f) {
                let search = f.search_index;
                searches.push(#{
                    name: search.name,
                    field_name: f.name,
                    method_name: "search_by_" + to_snake_case(search.name),
                    member_name: "search_by_" + to_snake_case(search.name),
                    key_type: search_key_type(f),
                    query_arg: search_query_arg(f),
                    query_expr: search_query_expr(f),
                    key_expr: search_key_expr(f),
                    is_token_mode: search.mode == "ngram" || search.mode == "word",
                    is_optional: f.field_type.is_option,
                    mode: search.mode,
                    n: search.n,
                    min: search.min,
                    normalize: search.normalize
                });
            }
        }
    }

    if s.indexes != () {
        for idx in s.indexes {
            if can_index(idx) {
                indexes.push(#{
                    name: idx.name,
                    field_name: idx.field_name,
                    member_name: to_snake_case(idx.name),
                    method_name: if idx.is_unique || idx.is_composite { "get_" + to_snake_case(idx.name) } else { "find_" + to_snake_case(idx.name) },
                    key_type: index_key_type(idx),
                    key_expr: index_key_expr(idx),
                    is_unique: idx.is_unique
                });
            }
        }
    }

    return #{
        def: s,
        rust_path: entry.rust_path,
        ref_name: safe + "Ref",
        table_name: safe + "RefTable",
        doc_member: to_snake_case(s.name) + "s",
        container_member: to_snake_case(s.name) + "s",
        indexes: indexes,
        searches: searches,
        fields: fields
    };
}

let tables = [];
for schema_file in schema.files {
    for ns in schema_file.namespaces {
        let entries = collect_structs_from_namespace(ns, rust_types::ns_to_module_name(ns.name));
        for entry in entries {
            tables.push(table_entry(entry));
        }
    }
}

let has_tables = tables.len() > 0;
let table_count = tables.len();
%endlogic
%if has_tables
