fn write_table<T, W>(writer: &mut W, table_name: &str, rows: &[T]) -> IoResult<()>
where
    T: BinaryIO,
    W: Write,
{
    writer.write_string(table_name)?;
    writer.write_u32(rows.len() as u32)?;
    for row in rows {
        let mut payload = Vec::new();
        row.write_binary(&mut payload)?;
        writer.write_u32(payload.len() as u32)?;
        writer.write_all(&payload)?;
    }
    Ok(())
}
%blank
fn skip_table<R: Read + Seek>(reader: &mut R) -> IoResult<Vec<usize>> {
    let row_count = reader.read_u32()? as usize;
    let mut offsets = Vec::with_capacity(row_count);
    for _ in 0..row_count {
        let len = reader.read_u32()? as usize;
        let row_offset = reader.stream_position()? as usize;
        offsets.push(row_offset);
        let mut skipped = vec![0u8; len];
        reader.read_exact(&mut skipped)?;
    }
    Ok(offsets)
}
