fn normalize_string(value: &str, policy: &str) -> String {
    match policy {
        "lower" => value.to_lowercase(),
        "trim" => value.trim().to_string(),
        "lower_trim" => value.trim().to_lowercase(),
        _ => value.to_string(),
    }
}
%blank
fn search_tokens(value: &str, mode: &str, n: usize, min: usize, normalize: &str) -> Vec<String> {
    let value = normalize_string(value, normalize);
    if value.len() < min {
        return Vec::new();
    }
    if mode == "exact" {
        return vec![value];
    }
%blank
    let mut seen = HashSet::new();
    let mut result = Vec::new();
    if mode == "word" {
        for token in value.split_whitespace() {
            if token.len() >= min && seen.insert(token.to_string()) {
                result.push(token.to_string());
            }
        }
        return result;
    }
%blank
    let chars: Vec<char> = value.chars().collect();
    if chars.len() < n {
        return Vec::new();
    }
    for index in 0..=(chars.len() - n) {
        let token: String = chars[index..index + n].iter().collect();
        if seen.insert(token.clone()) {
            result.push(token);
        }
    }
    result
}
