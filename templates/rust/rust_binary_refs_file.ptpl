pub fn read_binary_ref_document(bytes: Vec<u8>) -> IoResult<BinaryRefDocument> {
    let owner = Arc::new(bytes);
    let mut reader = Cursor::new(owner.as_slice());
    let mut magic = [0u8; 8];
    reader.read_exact(&mut magic)?;
    if &magic != BINARY_REF_MAGIC {
        return Err(invalid_data("invalid Rust BinaryRef document header"));
    }
    let table_count = reader.read_u32()? as usize;
%for table in tables
    let mut {{table.doc_member}}_offsets = Vec::new();
%endfor
    for _ in 0..table_count {
        let table_name = reader.read_string()?;
        match table_name.as_str() {
%for table in tables
            "{{table.def.fqn}}" => {
                {{table.doc_member}}_offsets = skip_table(&mut reader)?;
            }
%endfor
            _ => {
                let _ = skip_table(&mut reader)?;
            }
        }
    }
    Ok(BinaryRefDocument {
        owner: owner.clone(),
%for table in tables
        {{table.doc_member}}: {{table.table_name}}::from_offsets(owner.clone(), {{table.doc_member}}_offsets)?,
%endfor
    })
}
