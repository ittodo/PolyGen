pub fn write_binary_ref_document(container: &SchemaContainer) -> IoResult<Vec<u8>> {
    let mut writer = Vec::new();
    writer.write_all(BINARY_REF_MAGIC)?;
    writer.write_u32({{table_count}})?;
%for table in tables
    write_table(&mut writer, "{{table.def.fqn}}", container.{{table.container_member}}.all())?;
%endfor
    Ok(writer)
}
