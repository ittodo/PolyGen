    mutating func writeDate(_ value: Date) {
        let ticks = Int64((value.timeIntervalSince1970 * 10_000_000.0).rounded()) + 621_355_968_000_000_000
        writeInt64(ticks)
    }

    mutating func writeOptional<T>(_ value: T?, writer: (inout PolygenBinaryWriter, T) -> Void) {
        writeBool(value != nil)
        if let value {
            writer(&self, value)
        }
    }

    mutating func writeList<T>(_ value: [T], writer: (inout PolygenBinaryWriter, T) -> Void) {
        precondition(value.count <= Int(UInt32.max), "PolyGen binary list length exceeds UInt32.max")
        writeUInt32(UInt32(value.count))
        for item in value {
            writer(&self, item)
        }
    }
}

private func polygenJsonDecoder() -> JSONDecoder {
    let decoder = JSONDecoder()
    decoder.dateDecodingStrategy = .iso8601
    return decoder
}

private func polygenIsEmpty(_ value: String?) -> Bool {
    value == nil || value == ""
}

private func polygenRequired(_ value: String?, fieldName: String) throws -> String {
    guard let value, !value.isEmpty else {
        throw PolygenLoadError.missingRequiredField(fieldName)
    }
    return value
}

private func polygenReadCsvRows(_ path: String) throws -> [[String: String]] {
    let content = try String(contentsOfFile: path, encoding: .utf8)
    let lines = content.split(whereSeparator: \.isNewline).map(String.init)
    guard let headerLine = lines.first else {
        return []
    }
    let headers = polygenSplitCsvLine(headerLine)
    return lines.dropFirst().filter { !$0.isEmpty }.map { line in
        let values = polygenSplitCsvLine(line)
        var row: [String: String] = [:]
        for (index, header) in headers.enumerated() {
            row[header] = index < values.count ? values[index] : ""
        }
        return row
    }
}

private func polygenSplitCsvLine(_ line: String) -> [String] {
    var values: [String] = []
    var current = ""
    var inQuotes = false
    var index = line.startIndex
    while index < line.endIndex {
        let char = line[index]
        if char == "\"" {
            let next = line.index(after: index)
            if inQuotes && next < line.endIndex && line[next] == "\"" {
                current.append("\"")
                index = next
            } else {
                inQuotes.toggle()
            }
        } else if char == "," && !inQuotes {
            values.append(current)
            current = ""
        } else {
            current.append(char)
        }
        index = line.index(after: index)
    }
    values.append(current)
    return values
}

private func polygenParseList<T>(_ raw: String?, fieldName: String, parser: (String) throws -> T) throws -> [T] {
    if polygenIsEmpty(raw) {
        return []
    }
    return try polygenRequired(raw, fieldName: fieldName)
        .split(separator: ",")
        .map { String($0).trimmingCharacters(in: .whitespacesAndNewlines) }
        .filter { !$0.isEmpty }
        .map(parser)
}

private func polygenParseBool(_ raw: String, fieldName: String) throws -> Bool {
    switch raw.trimmingCharacters(in: .whitespacesAndNewlines).lowercased() {
    case "true", "1", "yes": return true
    case "false", "0", "no": return false
    default: throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
    }
}

private func polygenParseInteger<T: FixedWidthInteger>(_ raw: String, fieldName: String, as type: T.Type) throws -> T {
    guard let parsed = T(raw.trimmingCharacters(in: .whitespacesAndNewlines)) else {
        throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
    }
    return parsed
}

private func polygenParseFloating<T: BinaryFloatingPoint & LosslessStringConvertible>(_ raw: String, fieldName: String, as type: T.Type) throws -> T {
    guard let parsed = T(raw.trimmingCharacters(in: .whitespacesAndNewlines)), parsed.isFinite else {
        throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
    }
    return parsed
}

private func polygenParseData(_ raw: String, fieldName: String) throws -> Data {
    guard let data = Data(base64Encoded: raw.trimmingCharacters(in: .whitespacesAndNewlines)) else {
        throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
    }
    return data
}

private func polygenParseDate(_ raw: String, fieldName: String) throws -> Date {
    guard let date = ISO8601DateFormatter().date(from: raw.trimmingCharacters(in: .whitespacesAndNewlines)) else {
        throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
    }
    return date
}

private func polygenParseEnum<T: RawRepresentable & CaseIterable>(_ raw: String, fieldName: String, as type: T.Type) throws -> T where T.RawValue == Int {
    let trimmed = raw.trimmingCharacters(in: .whitespacesAndNewlines)
    if let rawValue = Int(trimmed), let parsed = T(rawValue: rawValue) {
        return parsed
    }
    if let parsed = T.allCases.first(where: { String(describing: $0) == trimmed }) {
        return parsed
    }
    throw PolygenLoadError.invalidValue(field: fieldName, value: raw)
}

%if has_pack
enum PolygenPackError: Error, Equatable {
    case invalidFieldCount(type: String, expected: Int, actual: Int)
    case invalidValue(field: String, value: String)
}

%endif

{{body}}
{{loaders}}
