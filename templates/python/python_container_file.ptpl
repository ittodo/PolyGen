%endif
%endfor
%for idx in entry.indexes
%if idx.is_unique
        seen: set[object] = set()
        for row in self._rows:
            key = {{idx.key_expr}}
            if key in seen:
                result.add_error(ValidationError(
                    table_name="{{entry.def.name}}",
                    field_name="{{idx.def.name}}",
                    row_key=str(getattr(row, "id", "")),
                    message=f"duplicate value {key!r} violates unique constraint",
                    constraint_type="Unique",
                ))
            else:
                seen.add(key)
%endif
%endfor
        return result

%for idx in entry.indexes
%if idx.is_unique
    def {{idx.get_method}}(self, key: object) -> Optional[{{entry.class_name}}]:
        return self._{{idx.attr_name}}.get(key)

%else
    def {{idx.find_method}}(self, key: object) -> list[{{entry.class_name}}]:
        return list(self._{{idx.attr_name}}.get(key, []))

%endif
%endfor
%for search in entry.search_indexes
%if search.is_token_mode
    def {{search.method}}(self, query: str) -> list[{{entry.class_name}}]:
        tokens = _search_tokens(query, "{{search.mode}}", {{search.n}}, {{search.min}}, "{{search.normalize}}")
        if len(tokens) == 0:
            return []
        postings: list[list[object]] = []
        for token in tokens:
            rows = self._{{search.attr_name}}.get(token)
            if rows is None:
                return []
            postings.append(rows)
        return _intersect_rows(postings)

%else
    def {{search.method}}(self, key: object) -> list[{{entry.class_name}}]:
%if search.is_exact_string
        if key is None:
