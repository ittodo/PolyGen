        normalized_key = _search_normalize(str(key), "{{search.normalize}}")
        return list(self._{{search.attr_name}}.get(normalized_key, []))
%else
        return list(self._{{search.attr_name}}.get(key, []))
%endif

%endif
%endfor

%endfor
class {{container_name}}:
    def __init__(self) -> None:
%for entry in entries
        self.{{entry.member_name}} = {{entry.table_class}}()
%endfor

    def clear(self) -> None:
%for entry in entries
        self.{{entry.member_name}}.clear()
%endfor

%for entry in entries
    def load_{{entry.member_name}}_from_csv(self, path: str | Path) -> None:
        self.{{entry.member_name}}.load_all({{entry.csv_loader}}(path))

    def load_{{entry.member_name}}_from_json(self, path: str | Path) -> None:
        self.{{entry.member_name}}.load_all({{entry.json_loader}}(path))

%endfor
    def load_from_csv(self, root: str | Path) -> None:
        root_path = Path(root)
%for entry in entries
%if entry.csv_pattern != ""
        self.load_{{entry.member_name}}_from_csv(root_path / {{entry.csv_literal}})
%endif
%endfor

    def load_from_json(self, root: str | Path) -> None:
        root_path = Path(root)
%for entry in entries
%if entry.json_pattern != ""
        self.load_{{entry.member_name}}_from_json(root_path / {{entry.json_literal}})
%endif
%endfor

    def validate_all(self) -> ValidationResult:
        result = ValidationResult()
%for entry in entries
        result.merge(self.{{entry.member_name}}.validate())
%endfor
%for check in fk_checks
        for row in self.{{check.source_member}}.all():
            target = self.{{check.target_member}}.{{check.target_method}}(row.{{check.field_name}})
            if target is None:
                result.add_error(ValidationError(
                    table_name={{check.source_table_literal}},
                    field_name={{check.field_name_literal}},
                    row_key=str(getattr(row, "id", "")),
                    message=f"foreign key reference not found in {{check.target_table}}: {row.{{check.field_name}}!r}",
                    constraint_type="ForeignKey",
                ))
%endfor
        return result

    def validate_or_raise(self) -> None:
        result = self.validate_all()
        if not result.is_valid():
            raise ValidationException(result)

%for nav in forward_navs
    def {{nav.method_name}}(self, row: {{nav.source_class}}) -> Optional[{{nav.target_class}}]:
        key = row.{{nav.field_name}}
        if key is None:
            return None
        return self.{{nav.target_member}}.{{nav.target_method}}(key)

%endfor
%for nav in reverse_navs
    def {{nav.method_name}}(self, row: {{nav.target_class}}) -> list[{{nav.source_class}}]:
        return self.{{nav.source_member}}.{{nav.source_method}}(row.{{nav.target_key_field}})

%endfor
