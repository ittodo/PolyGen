def _read_i8_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<b")
def _read_u16_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<H")
def _read_i16_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<h")
def _read_u32_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<I")
def _read_i32_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<i")
def _read_u64_at(data: memoryview, offset: int) -> int: return _read_at(data, offset, "<Q")
