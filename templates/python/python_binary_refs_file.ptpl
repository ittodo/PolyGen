%logic
import "templates/python/rhai_utils/type_mapping" as py;

fn collect_tables_from_namespace(ns) {
    let tables = [];
    for item in ns.items {
        if item.is_struct {
            let s = item.as_struct();
            if !s.is_embed {
                tables.push(s);
            }
        } else if item.is_namespace {
            let child_tables = collect_tables_from_namespace(item.as_namespace());
            for child in child_tables {
                tables.push(child);
            }
        }
    }
    tables
}

fn table_member_name(s) {
    to_snake_case(s.name) + "s"
}

fn ref_name(s) {
    py::class_name_from_fqn(s.fqn) + "Ref"
}

fn table_ref_name(s) {
    py::class_name_from_fqn(s.fqn) + "RefTable"
}

fn codec_name(s) {
    py::class_name_from_fqn(s.fqn) + "RefCodec"
}

fn method_suffix(name) {
    to_snake_case(name)
}

fn is_supported_base(t) {
    if t.type_name == "string" || t.type_name == "bytes" || t.type_name == "bool" || t.type_name == "timestamp" {
        return true;
    }
    if t.is_enum {
        return true;
    }
    if t.is_primitive && t.type_name != "bytes" {
        return true;
    }
    return false;
}

fn is_supported_field(t) {
    if t.is_list {
        return false;
    }
    let base = if t.is_option { t.inner } else { t };
    is_supported_base(base)
}

fn index_field_type(struct_def, index_field) {
    for item in struct_def.items {
        if item.is_field {
            let field = item.as_field();
            if field.name == index_field.name {
                return field.field_type;
            }
        }
    }
    return index_field.field_type;
}

fn single_index_type(struct_def, idx) {
    for item in struct_def.items {
        if item.is_field {
            let field = item.as_field();
            if field.name == idx.field_name {
                return field.field_type;
            }
        }
    }
    return idx.field_type;
}

fn is_supported_index_type(t) {
    if t.is_option || t.is_list {
        return false;
    }
    if t.type_name == "bytes" || t.type_name == "f32" || t.type_name == "f64" {
        return false;
    }
    is_supported_base(t)
}

fn is_supported_index(struct_def, idx) {
    if idx.is_composite {
        for field in idx.fields {
            if !is_supported_index_type(index_field_type(struct_def, field)) {
                return false;
            }
        }
        return true;
    }
    is_supported_index_type(single_index_type(struct_def, idx))
}

fn search_base_type(t) {
    if t.is_option {
        return t.inner;
    }
    t
}

fn is_search_target_enabled(search) {
    search.target == "csharp" || search.target == "python" || search.target == "python_binary_ref"
}

fn is_supported_search(f) {
    if !f.has_search_index {
        return false;
    }
    let search = f.search_index;
    if !is_search_target_enabled(search) {
        return false;
    }
    let ft = f.field_type;
    if ft.is_list {
        return false;
    }
    let base = search_base_type(ft);
    if search.mode == "ngram" || search.mode == "word" {
        return base.type_name == "string";
    }
    if search.mode != "exact" {
        return false;
    }
    if base.type_name == "string" || base.type_name == "bool" || base.type_name == "timestamp" {
        return true;
    }
    if base.is_enum {
        return true;
    }
    if base.is_primitive && base.type_name != "bytes" && base.type_name != "f32" && base.type_name != "f64" {
        return true;
    }
    return false;
}

fn read_at_expr(t, offset_expr) {
    if t.type_name == "string" { return "_read_string_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "bytes" { return "_read_bytes_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "bool" { return "_read_bool_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "u8" { return "_read_u8_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "i8" { return "_read_i8_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "u16" { return "_read_u16_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "i16" { return "_read_i16_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "u32" { return "_read_u32_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "i32" { return "_read_i32_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "u64" { return "_read_u64_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "i64" { return "_read_i64_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "f32" { return "_read_f32_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "f64" { return "_read_f64_at(self._owner.data, " + offset_expr + ")"; }
    if t.type_name == "timestamp" { return "_read_timestamp_at(self._owner.data, " + offset_expr + ")"; }
    if t.is_enum { return "_types." + py::class_name_for_type(t) + "(_read_i32_at(self._owner.data, " + offset_expr + "))"; }
    return "_read_i32_at(self._owner.data, " + offset_expr + ")";
}

fn reader_expr(t, reader_expr) {
    if t.type_name == "string" { return reader_expr + ".read_string()"; }
    if t.type_name == "bytes" { return reader_expr + ".read_bytes()"; }
    if t.type_name == "bool" { return reader_expr + ".read_bool()"; }
    if t.type_name == "u8" { return reader_expr + ".read_u8()"; }
    if t.type_name == "i8" { return reader_expr + ".read_i8()"; }
    if t.type_name == "u16" { return reader_expr + ".read_u16()"; }
    if t.type_name == "i16" { return reader_expr + ".read_i16()"; }
    if t.type_name == "u32" { return reader_expr + ".read_u32()"; }
    if t.type_name == "i32" { return reader_expr + ".read_i32()"; }
    if t.type_name == "u64" { return reader_expr + ".read_u64()"; }
    if t.type_name == "i64" { return reader_expr + ".read_i64()"; }
    if t.type_name == "f32" { return reader_expr + ".read_f32()"; }
    if t.type_name == "f64" { return reader_expr + ".read_f64()"; }
    if t.type_name == "timestamp" { return reader_expr + ".read_timestamp()"; }
    if t.is_enum { return "_types." + py::class_name_for_type(t) + "(" + reader_expr + ".read_i32())"; }
    return reader_expr + ".read_i32()";
}

fn writer_call(t, writer_expr, value_expr) {
    if t.type_name == "string" { return writer_expr + ".write_string(" + value_expr + ")"; }
    if t.type_name == "bytes" { return writer_expr + ".write_bytes(" + value_expr + ")"; }
    if t.type_name == "bool" { return writer_expr + ".write_bool(" + value_expr + ")"; }
    if t.type_name == "u8" { return writer_expr + ".write_u8(" + value_expr + ")"; }
    if t.type_name == "i8" { return writer_expr + ".write_i8(" + value_expr + ")"; }
    if t.type_name == "u16" { return writer_expr + ".write_u16(" + value_expr + ")"; }
    if t.type_name == "i16" { return writer_expr + ".write_i16(" + value_expr + ")"; }
    if t.type_name == "u32" { return writer_expr + ".write_u32(" + value_expr + ")"; }
    if t.type_name == "i32" { return writer_expr + ".write_i32(" + value_expr + ")"; }
    if t.type_name == "u64" { return writer_expr + ".write_u64(" + value_expr + ")"; }
    if t.type_name == "i64" { return writer_expr + ".write_i64(" + value_expr + ")"; }
    if t.type_name == "f32" { return writer_expr + ".write_f32(" + value_expr + ")"; }
    if t.type_name == "f64" { return writer_expr + ".write_f64(" + value_expr + ")"; }
    if t.type_name == "timestamp" { return writer_expr + ".write_timestamp(" + value_expr + ")"; }
    if t.is_enum { return "_write_enum(" + writer_expr + ", _types." + py::class_name_for_type(t) + ", " + value_expr + ")"; }
    return writer_expr + ".write_i32(int(" + value_expr + "))";
}

fn index_key_expr(idx) {
    if idx.is_composite {
        let result = "(";
        for i in 0..idx.fields.len() {
            if i > 0 {
                result += ", ";
            }
            result += "row." + idx.fields[i].name;
        }
        result += ")";
        return result;
    }
    return "row." + idx.field_name;
}

fn index_api_name(idx) {
    if idx.is_composite {
        let result = "";
        for i in 0..idx.fields.len() {
            if i > 0 {
                result += "_";
            }
            result += idx.fields[i].name;
        }
        return result;
    }
    idx.field_name
}

fn index_read_key_expr(struct_def, idx) {
    if idx.is_composite {
        let result = "(";
        for i in 0..idx.fields.len() {
            if i > 0 {
                result += ", ";
            }
            result += reader_expr(index_field_type(struct_def, idx.fields[i]), "reader");
        }
        result += ")";
        return result;
    }
    return reader_expr(single_index_type(struct_def, idx), "reader");
}

fn index_write_key_expr(struct_def, idx) {
    if idx.is_composite {
        let result = "";
        for i in 0..idx.fields.len() {
            if i > 0 {
                result += "\n            ";
            }
            result += writer_call(index_field_type(struct_def, idx.fields[i]), "writer", "key[" + i + "]");
        }
        return result;
    }
    return writer_call(single_index_type(struct_def, idx), "writer", "key");
}

fn key_expr(field_name, is_option) {
    let value = "row." + field_name;
    if is_option {
        return value;
    }
    value
}

fn exact_search_key_expr(search) {
    let value = "row." + search.field_name;
    if search.is_exact_string {
        return "_search_normalize(" + value + ", " + py::quote_py_string(search.normalize) + ")";
    }
    return value;
}

let all_tables = [];
for ns in file.namespaces {
    let tables = collect_tables_from_namespace(ns);
    for table in tables {
        all_tables.push(table);
    }
}

let entries = [];
for s in all_tables {
    let fields = [];
    let field_index = 0;
    for item in s.items {
        if item.is_field {
            let f = item.as_field();
            let base = if f.field_type.is_option { f.field_type.inner } else { f.field_type };
            if is_supported_field(f.field_type) {
                fields.push(#{
                    def: f,
                    index: field_index,
                    name: f.name,
                    base: base,
                    is_option: f.field_type.is_option,
                    read_at: read_at_expr(base, "offset"),
                    write_call: writer_call(base, "writer", "row." + f.name),
                    write_value_call: writer_call(base, "writer", "value")
                });
            }
            field_index += 1;
        }
    }

    let indexes = [];
    for idx in s.indexes {
        if is_supported_index(s, idx) {
            let method_name_source = index_api_name(idx);
            indexes.push(#{
                def: idx,
                attr_name: to_snake_case(idx.name),
                name_literal: py::quote_py_string(idx.name),
                method_name: if idx.is_unique { "get_by_" + method_suffix(method_name_source) } else { "find_by_" + method_suffix(method_name_source) },
                field_name: idx.field_name,
                key_expr: index_key_expr(idx),
                is_unique: idx.is_unique,
                is_unique_literal: if idx.is_unique { "True" } else { "False" },
                read_key: index_read_key_expr(s, idx),
                write_key: index_write_key_expr(s, idx)
            });
        }
    }

    let search_indexes = [];
    for item in s.items {
        if item.is_field {
            let f = item.as_field();
            if is_supported_search(f) {
                let search = f.search_index;
                let base = search_base_type(f.field_type);
                let is_token_mode = search.mode == "ngram" || search.mode == "word";
                search_indexes.push(#{
                    def: f,
                    name: search.name,
                    name_literal: py::quote_py_string(search.name),
                    attr_name: "search_" + to_snake_case(search.name),
                    method_name: "search_by_" + to_snake_case(search.name),
                    field_name: f.name,
                    mode: search.mode,
                    mode_literal: py::quote_py_string(search.mode),
                    normalize: search.normalize,
                    normalize_literal: py::quote_py_string(search.normalize),
                    n: search.n,
                    min: search.min,
                    is_option: f.field_type.is_option,
                    is_token_mode: is_token_mode,
                    is_exact_string: search.mode == "exact" && base.type_name == "string",
                    read_key: if is_token_mode { "reader.read_string()" } else { reader_expr(base, "reader") },
                    write_key: if is_token_mode { "writer.write_string(key)" } else { writer_call(base, "writer", "key") },
                    exact_key_expr: exact_search_key_expr(#{
                        field_name: f.name,
                        is_exact_string: search.mode == "exact" && base.type_name == "string",
                        normalize: search.normalize
                    })
                });
            }
        }
    }

    entries.push(#{
        def: s,
        class_name: py::class_name_from_fqn(s.fqn),
        fqn_literal: py::quote_py_string(s.fqn),
        ref_name: ref_name(s),
        table_name: table_ref_name(s),
        codec_name: codec_name(s),
        member_name: table_member_name(s),
        fields: fields,
        field_count: field_index,
        indexes: indexes,
        index_count: indexes.len(),
        search_indexes: search_indexes,
        search_index_count: search_indexes.len()
    });
}

let base_name = file.path;
if base_name.contains("/") {
    let parts = base_name.split("/");
    base_name = parts[parts.len() - 1];
}
if base_name.ends_with(".poly") {
    base_name = base_name.sub_string(0, base_name.len() - 5);
}
let context_name = to_pascal_case(base_name) + "BinaryRefContext";
let container_name = to_pascal_case(base_name) + "BinaryRefContainer";
let entry_count = entries.len();
%endlogic
