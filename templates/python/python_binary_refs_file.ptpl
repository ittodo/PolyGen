            if payload is not None:
                writer.write_raw(payload)
        return writer.to_bytes()


def _search_normalize(value: str, policy: str) -> str:
    result = value
    if policy in ("trim", "lower_trim"):
        result = result.strip()
    if policy in ("lower", "lower_trim"):
        result = result.lower()
    return result


def _search_tokens(value: str, mode: str, n: int, min_size: int, normalize: str) -> list[str]:
    normalized = _search_normalize(value, normalize)
    tokens: set[str] = set()
    if mode == "exact":
        if normalized or min_size <= 0:
            tokens.add(normalized)
    elif mode == "word":
        tokens.update(token for token in normalized.split() if len(token) >= min_size)
    else:
        if n <= 0:
            raise ValueError("search ngram size must be positive")
        if len(normalized) >= max(n, min_size):
            for index in range(0, len(normalized) - n + 1):
                token = normalized[index:index + n]
                if len(token) >= min_size:
                    tokens.add(token)
    return sorted(tokens)


def _search_intersect(postings: list[list[int]]) -> list[int]:
    if not postings:
        return []
    current = set(postings[0])
    for values in postings[1:]:
        current &= set(values)
        if not current:
            return []
    return sorted(current)


%for entry in entries
class {{entry.ref_name}}:
    def __init__(self, owner: _BinaryDocumentOwner, row_offset: int):
        self._owner = owner
        self._row_offset = row_offset

    def _required_field_offset(self, field_index: int) -> int:
        return _require_field_offset(self._owner.data, self._row_offset, field_index)

    def _optional_field_offset(self, field_index: int) -> int:
        return _get_field_offset(self._owner.data, self._row_offset, field_index)

%for field_entry in entry.fields
%if field_entry.is_option
    @property
    def has_{{field_entry.name}}(self) -> bool:
        return self._optional_field_offset({{field_entry.index}}) >= 0

    @property
    def {{field_entry.name}}(self) -> Any:
        offset = self._optional_field_offset({{field_entry.index}})
        if offset < 0:
            return None
        return {{field_entry.read_at}}

%else
    @property
    def {{field_entry.name}}(self) -> Any:
        offset = self._required_field_offset({{field_entry.index}})
        return {{field_entry.read_at}}

%endif
%endfor
    def to_owned(self) -> _types.{{entry.class_name}}:
        return _types.{{entry.class_name}}(
%for field_entry in entry.fields
            {{field_entry.name}}=self.{{field_entry.name}},
%endfor
        )

    def get(self) -> _types.{{entry.class_name}}:
        return self.to_owned()


class {{entry.codec_name}}:
    @staticmethod
    def write_row(row: _types.{{entry.class_name}}) -> bytes:
        builder = _BinaryRefRowBuilder({{entry.field_count}})
%for field_entry in entry.fields
%if field_entry.is_option
        if row.{{field_entry.name}} is not None:
            builder.set_field({{field_entry.index}}, lambda writer, value=row.{{field_entry.name}}: {{field_entry.write_value_call}})
%else
        builder.set_field({{field_entry.index}}, lambda writer: {{field_entry.write_call}})
%endif
%endfor
        return builder.to_bytes()


class {{entry.table_name}}:
    def __init__(
        self,
        owner: _BinaryDocumentOwner,
        row_offsets: list[int],
%for idx in entry.indexes
        {{idx.attr_name}}: dict[Any, Any],
%endfor
%for search in entry.search_indexes
        {{search.attr_name}}: dict[Any, list[int]],
%endfor
    ):
        self._owner = owner
        self._row_offsets = row_offsets
%for idx in entry.indexes
        self._{{idx.attr_name}} = {{idx.attr_name}}
%endfor
%for search in entry.search_indexes
        self._{{search.attr_name}} = {{search.attr_name}}
%endfor

    def count(self) -> int:
        return len(self._row_offsets)

    def all(self) -> list[{{entry.ref_name}}]:
        return [{{entry.ref_name}}(self._owner, offset) for offset in self._row_offsets]

    def at(self, index: int) -> {{entry.ref_name}}:
        return {{entry.ref_name}}(self._owner, self._row_offsets[index])

    def _refs_from_ordinals(self, ordinals: Iterable[int]) -> list[{{entry.ref_name}}]:
        return [{{entry.ref_name}}(self._owner, self._row_offsets[ordinal]) for ordinal in ordinals if 0 <= ordinal < len(self._row_offsets)]

%for idx in entry.indexes
%if idx.is_unique
    def {{idx.method_name}}(self, key: Any) -> Optional[{{entry.ref_name}}]:
        offset = self._{{idx.attr_name}}.get(key)
        if offset is None:
            return None
        return {{entry.ref_name}}(self._owner, offset)

%else
    def {{idx.method_name}}(self, key: Any) -> list[{{entry.ref_name}}]:
        return [{{entry.ref_name}}(self._owner, offset) for offset in self._{{idx.attr_name}}.get(key, [])]

%endif
%endfor
%for search in entry.search_indexes
%if search.is_token_mode
    def {{search.method_name}}(self, query: str) -> list[{{entry.ref_name}}]:
        tokens = _search_tokens(query, {{search.mode_literal}}, {{search.n}}, {{search.min}}, {{search.normalize_literal}})
        if not tokens:
            return []
        postings: list[list[int]] = []
        for token in tokens:
            ordinals = self._{{search.attr_name}}.get(token)
            if not ordinals:
                return []
            postings.append(ordinals)
        return self._refs_from_ordinals(_search_intersect(postings))

%else
    def {{search.method_name}}(self, key: Any) -> list[{{entry.ref_name}}]:
%if search.is_exact_string
        key = _search_normalize(key, {{search.normalize_literal}})
%endif
        return self._refs_from_ordinals(self._{{search.attr_name}}.get(key, []))

%endif
%endfor
    @staticmethod
    def write(writer: _BinaryRefWriter, source_rows: list[_types.{{entry.class_name}}]) -> None:
        writer.write_string({{entry.fqn_literal}})
        rows: list[tuple[_types.{{entry.class_name}}, int, bytes]] = []
        cursor = 0
        for row in source_rows:
            row_bytes = {{entry.codec_name}}.write_row(row)
            rows.append((row, cursor, row_bytes))
            cursor += len(row_bytes)

        writer.write_i32(len(rows))
        for _, offset, _ in rows:
            writer.write_i32(offset)

        writer.write_i32({{entry.index_count}})
%for idx in entry.indexes
        writer.write_string({{idx.name_literal}})
        writer.write_bool({{idx.is_unique_literal}})
%if idx.is_unique
        index: dict[Any, int] = {}
        for row, offset, _ in rows:
            index[{{idx.key_expr}}] = offset
        writer.write_i32(len(index))
        for key, offset in index.items():
            {{idx.write_key}}
            writer.write_i32(offset)
%else
        index: dict[Any, list[int]] = {}
        for row, offset, _ in rows:
            index.setdefault({{idx.key_expr}}, []).append(offset)
        writer.write_i32(len(index))
        for key, offsets in index.items():
            {{idx.write_key}}
            writer.write_i32(len(offsets))
            for offset in offsets:
                writer.write_i32(offset)
%endif
%endfor
        writer.write_i32({{entry.search_index_count}})
%for search in entry.search_indexes
        writer.write_string({{search.name_literal}})
        writer.write_string({{search.mode_literal}})
%if search.is_token_mode
        search_index: dict[Any, list[int]] = {}
        for ordinal, (row, _, _) in enumerate(rows):
            value = row.{{search.field_name}}
            if value is None:
                continue
            for token in _search_tokens(value, {{search.mode_literal}}, {{search.n}}, {{search.min}}, {{search.normalize_literal}}):
                search_index.setdefault(token, []).append(ordinal)
%else
        search_index: dict[Any, list[int]] = {}
        for ordinal, (row, _, _) in enumerate(rows):
            value = row.{{search.field_name}}
            if value is None:
                continue
            key = {{search.exact_key_expr}}
            search_index.setdefault(key, []).append(ordinal)
%endif
        writer.write_i32(len(search_index))
        for key, ordinals in search_index.items():
            {{search.write_key}}
            writer.write_i32(len(ordinals))
            for ordinal in ordinals:
                writer.write_i32(ordinal)
%endfor
        writer.write_i32(cursor)
        for _, _, row_bytes in rows:
            writer.write_raw(row_bytes)

    @staticmethod
    def read(owner: _BinaryDocumentOwner, reader: _BinaryRefReader) -> {{entry.table_name}}:
        table_name = reader.read_string()
        if table_name != {{entry.fqn_literal}}:
            raise ValueError(f"expected table {{entry.def.fqn}} but found {table_name}")
        row_count = reader.read_i32()
        if row_count < 0:
            raise ValueError("negative row count")
        row_offsets = [reader.read_i32() for _ in range(row_count)]

        index_count = reader.read_i32()
        if index_count != {{entry.index_count}}:
            raise ValueError(f"unexpected index count for {{entry.def.fqn}}: {index_count}")
%for idx in entry.indexes
        {{idx.attr_name}}: dict[Any, Any] = {}
        index_name = reader.read_string()
        if index_name != {{idx.name_literal}}:
            raise ValueError(f"expected index {{idx.def.name}} but found {index_name}")
        is_unique = reader.read_bool()
        if is_unique is not {{idx.is_unique_literal}}:
            raise ValueError("binary index uniqueness does not match generated schema")
        entry_count = reader.read_i32()
        if entry_count < 0:
            raise ValueError("negative index entry count")
        for _ in range(entry_count):
            key = {{idx.read_key}}
%if idx.is_unique
            {{idx.attr_name}}[key] = reader.read_i32()
%else
            value_count = reader.read_i32()
            if value_count < 0:
                raise ValueError("negative group index value count")
            {{idx.attr_name}}[key] = [reader.read_i32() for _ in range(value_count)]
%endif
%endfor
        search_index_count = reader.read_i32()
        if search_index_count != {{entry.search_index_count}}:
            raise ValueError(f"unexpected search index count for {{entry.def.fqn}}: {search_index_count}")
%for search in entry.search_indexes
        {{search.attr_name}}: dict[Any, list[int]] = {}
        search_index_name = reader.read_string()
        if search_index_name != {{search.name_literal}}:
            raise ValueError(f"expected search index {{search.name}} but found {search_index_name}")
        search_mode = reader.read_string()
        if search_mode != {{search.mode_literal}}:
            raise ValueError("binary search mode does not match generated schema")
        entry_count = reader.read_i32()
        if entry_count < 0:
            raise ValueError("negative search index entry count")
        for _ in range(entry_count):
            key = {{search.read_key}}
            value_count = reader.read_i32()
            if value_count < 0:
                raise ValueError("negative search index value count")
            {{search.attr_name}}[key] = [reader.read_i32() for _ in range(value_count)]
%endfor
        row_block_length = reader.read_i32()
        if row_block_length < 0:
            raise ValueError("negative row block length")
        row_block_start = reader.position()
        reader.skip(row_block_length)

        row_offsets = [row_block_start + offset for offset in row_offsets]
%for idx in entry.indexes
%if idx.is_unique
        {{idx.attr_name}} = {key: row_block_start + offset for key, offset in {{idx.attr_name}}.items()}
%else
        {{idx.attr_name}} = {key: [row_block_start + offset for offset in offsets] for key, offsets in {{idx.attr_name}}.items()}
%endif
%endfor
        return {{entry.table_name}}(
            owner,
            row_offsets,
%for idx in entry.indexes
            {{idx.attr_name}},
%endfor
%for search in entry.search_indexes
            {{search.attr_name}},
%endfor
        )


%endfor
@dataclass
class {{container_name}}:
%if entry_count == 0
    pass
%else
%for entry in entries
    {{entry.member_name}}: list[_types.{{entry.class_name}}] = field(default_factory=list)
%endfor
%endif


class {{context_name}}:
    def __init__(
        self,
        owner: _BinaryDocumentOwner,
%for entry in entries
        {{entry.member_name}}: {{entry.table_name}},
%endfor
    ):
        self._owner = owner
%for entry in entries
        self.{{entry.member_name}} = {{entry.member_name}}
%endfor

    @classmethod
    def open_binary(cls, data: bytes | bytearray | memoryview) -> {{context_name}}:
        owner = _BinaryDocumentOwner(data)
        reader = _BinaryRefReader(owner.data)
        _read_header(reader)
        table_count = reader.read_i32()
        if table_count != {{entry_count}}:
            raise ValueError(f"unexpected table count: {table_count}")
%for entry in entries
        {{entry.member_name}} = {{entry.table_name}}.read(owner, reader)
%endfor
        return cls(
            owner,
%for entry in entries
            {{entry.member_name}},
%endfor
        )

    @staticmethod
    def save_binary(container: {{container_name}}) -> bytes:
        writer = _BinaryRefWriter()
        _write_header(writer)
        writer.write_i32({{entry_count}})
%for entry in entries
        {{entry.table_name}}.write(writer, container.{{entry.member_name}})
%endfor
        return writer.to_bytes()


class BinaryRefDocument:
    def __init__(self, data: bytes, context: {{context_name}}):
        self._data = data
        self._context = context
%for entry in entries
        self.{{entry.member_name}} = context.{{entry.member_name}}
%endfor

    @classmethod
    def from_bytes(cls, data: bytes | bytearray | memoryview) -> BinaryRefDocument:
        raw = bytes(data)
        return cls(raw, {{context_name}}.open_binary(raw))

    @classmethod
    def from_container(cls, container: Any) -> BinaryRefDocument:
        binary_container = {{container_name}}(
%for entry in entries
            {{entry.member_name}}=list(container.{{entry.member_name}}.all()),
%endfor
        )
        return cls.from_bytes({{context_name}}.save_binary(binary_container))

    def to_bytes(self) -> bytes:
        return self._data
