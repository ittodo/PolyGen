%for tbl in sqlite_tables
    def {{tbl.load_method}}(self) -> None:
        cursor = self.connection.execute("SELECT {{tbl.columns}} FROM {{tbl.table_name}}")
        self.{{tbl.member_name}}.load_all(_map_{{tbl.member_name}}(row) for row in cursor.fetchall())

%if tbl.has_pk
    def {{tbl.get_method}}(self, key: object) -> Optional[Types.{{tbl.class_name}}]:
        cursor = self.connection.execute(
            "SELECT {{tbl.columns}} FROM {{tbl.table_name}} WHERE {{tbl.pk_name}} = ?",
            (key,),
