%if idx.is_composite
%for field in idx.fields
%if field.is_enum
			if err := writer.WriteInt32(int32(key.{{field.go_name}})); err != nil { return err }
%else
			if err := writer.{{field.write_method}}(key.{{field.go_name}}); err != nil { return err }
%endif
%endfor
%else
%if idx.is_enum
			if err := writer.WriteInt32(int32(key)); err != nil { return err }
%else
			if err := writer.{{idx.write_method}}(key); err != nil { return err }
%endif
%endif
			if err := writer.WriteInt32(int32(offset)); err != nil { return err }
		}
	}
%else
	{
		index := make(map[{{idx.key_type}}][]int)
		for _, row := range rows {
%if idx.is_composite
			key := {{idx.key_type}}{
%for field in idx.fields
				{{field.go_name}}: row.row.{{field.go_name}},
%endfor
			}
			index[key] = append(index[key], row.offset)
%else
			index[row.row.{{idx.field_go_name}}] = append(index[row.row.{{idx.field_go_name}}], row.offset)
%endif
		}
		if err := writer.WriteInt32(int32(len(index))); err != nil { return err }
		for key, offsets := range index {
%if idx.is_composite
%for field in idx.fields
%if field.is_enum
			if err := writer.WriteInt32(int32(key.{{field.go_name}})); err != nil { return err }
%else
			if err := writer.{{field.write_method}}(key.{{field.go_name}}); err != nil { return err }
%endif
%endfor
%else
%if idx.is_enum
			if err := writer.WriteInt32(int32(key)); err != nil { return err }
%else
			if err := writer.{{idx.write_method}}(key); err != nil { return err }
%endif
%endif
			if err := writer.WriteInt32(int32(len(offsets))); err != nil { return err }
			for _, offset := range offsets {
				if err := writer.WriteInt32(int32(offset)); err != nil { return err }
			}
		}
	}
%endif
%endfor
	if err := writer.WriteInt32({{entry.search_index_count}}); err != nil {
		return err
	}
%for search in entry.search_indexes
	if err := writer.WriteString("{{search.name}}"); err != nil { return err }
	if err := writer.WriteString("{{search.mode}}"); err != nil { return err }
%if search.is_token_mode
	{
		index := make(map[string][]int)
		for ordinal, row := range rows {
%if search.is_option
			if row.row.{{search.field_go_name}} == nil { continue }
			for _, token := range binaryRefSearchTokens(*row.row.{{search.field_go_name}}, "{{search.mode}}", {{search.n}}, {{search.min}}, "{{search.normalize}}") {
				binaryRefSearchAdd(index, token, ordinal)
			}
%else
			for _, token := range binaryRefSearchTokens(row.row.{{search.field_go_name}}, "{{search.mode}}", {{search.n}}, {{search.min}}, "{{search.normalize}}") {
				binaryRefSearchAdd(index, token, ordinal)
			}
%endif
		}
		if err := writer.WriteInt32(int32(len(index))); err != nil { return err }
		for key, ordinals := range index {
			if err := writer.WriteString(key); err != nil { return err }
			if err := writer.WriteInt32(int32(len(ordinals))); err != nil { return err }
			for _, ordinal := range ordinals {
				if err := writer.WriteInt32(int32(ordinal)); err != nil { return err }
			}
		}
	}
%else
	{
		index := make(map[{{search.key_type}}][]int)
		for ordinal, row := range rows {
%if search.is_option
			if row.row.{{search.field_go_name}} == nil { continue }
%if search.is_exact_string
			key := binaryRefSearchNormalize(*row.row.{{search.field_go_name}}, "{{search.normalize}}")
%else
			key := *row.row.{{search.field_go_name}}
%endif
%else
%if search.is_exact_string
			key := binaryRefSearchNormalize(row.row.{{search.field_go_name}}, "{{search.normalize}}")
%else
			key := row.row.{{search.field_go_name}}
%endif
%endif
			binaryRefSearchAdd(index, key, ordinal)
		}
		if err := writer.WriteInt32(int32(len(index))); err != nil { return err }
		for key, ordinals := range index {
%if search.is_enum
			if err := writer.WriteInt32(int32(key)); err != nil { return err }
%else
			if err := writer.{{search.write_method}}(key); err != nil { return err }
%endif
			if err := writer.WriteInt32(int32(len(ordinals))); err != nil { return err }
			for _, ordinal := range ordinals {
				if err := writer.WriteInt32(int32(ordinal)); err != nil { return err }
			}
		}
	}
%endif
%endfor
	if err := writer.WriteInt32(int32(cursor)); err != nil {
		return err
	}
	for _, row := range rows {
		if err := writer.WriteRaw(row.bytes); err != nil {
			return err
		}
	}
	return nil
}

func read{{entry.table_name}}(owner *BinaryDocumentOwner, reader *BinaryRefCursor) (*{{entry.table_name}}, error) {
	tableName, err := reader.ReadString()
	if err != nil {
		return nil, err
	}
	if tableName != "{{entry.def.fqn}}" {
		return nil, fmt.Errorf("expected table {{entry.def.fqn}} but found %s", tableName)
	}
	rowCount, err := reader.ReadInt32()
	if err != nil {
		return nil, err
	}
	if rowCount < 0 {
		return nil, fmt.Errorf("negative row count")
	}
	rowOffsets := make([]int, int(rowCount))
	for i := 0; i < int(rowCount); i++ {
		offset, err := reader.ReadInt32()
		if err != nil {
			return nil, err
		}
		rowOffsets[i] = int(offset)
	}
	indexCount, err := reader.ReadInt32()
	if err != nil {
		return nil, err
	}
	if indexCount != {{entry.index_count}} {
		return nil, fmt.Errorf("unexpected index count for {{entry.def.fqn}}: %d", indexCount)
	}
%for idx in entry.indexes
%if idx.is_unique
	{{idx.var_name}} := make(map[{{idx.key_type}}]int)
%else
	{{idx.var_name}} := make(map[{{idx.key_type}}][]int)
%endif
	{
		indexName, err := reader.ReadString()
		if err != nil { return nil, err }
		if indexName != "{{idx.def.name}}" { return nil, fmt.Errorf("expected index {{idx.def.name}} but found %s", indexName) }
		isUnique, err := reader.ReadBool()
		if err != nil { return nil, err }
		if isUnique != {{idx.is_unique_literal}} { return nil, fmt.Errorf("binary index uniqueness does not match generated schema") }
		entryCount, err := reader.ReadInt32()
		if err != nil { return nil, err }
		if entryCount < 0 { return nil, fmt.Errorf("negative index entry count") }
		for i := 0; i < int(entryCount); i++ {
%if idx.is_composite
%for field in idx.fields
%if field.is_enum
			raw{{field.key_var}}, err := reader.ReadInt32()
			if err != nil { return nil, err }
			{{field.key_var}} := {{field.key_type}}(raw{{field.key_var}})
%else
			{{field.key_var}}, err := reader.{{field.read_method}}()
			if err != nil { return nil, err }
%endif
%endfor
			key := {{idx.key_type}}{
%for field in idx.fields
				{{field.go_name}}: {{field.key_var}},
%endfor
			}
%else
%if idx.is_enum
			rawKey, err := reader.ReadInt32()
			if err != nil { return nil, err }
			key := {{idx.key_type}}(rawKey)
%else
			key, err := reader.{{idx.read_method}}()
			if err != nil { return nil, err }
%endif
%endif
%if idx.is_unique
			offset, err := reader.ReadInt32()
			if err != nil { return nil, err }
			{{idx.var_name}}[key] = int(offset)
%else
			valueCount, err := reader.ReadInt32()
			if err != nil { return nil, err }
			if valueCount < 0 { return nil, fmt.Errorf("negative group index value count") }
			offsets := make([]int, int(valueCount))
			for j := 0; j < int(valueCount); j++ {
				offset, err := reader.ReadInt32()
				if err != nil { return nil, err }
				offsets[j] = int(offset)
			}
			{{idx.var_name}}[key] = offsets
%endif
		}
	}
%endfor
	searchIndexCount, err := reader.ReadInt32()
	if err != nil {
		return nil, err
	}
	if searchIndexCount != {{entry.search_index_count}} {
		return nil, fmt.Errorf("unexpected search index count for {{entry.def.fqn}}: %d", searchIndexCount)
	}
%for search in entry.search_indexes
	{{search.var_name}} := make(map[{{search.key_type}}][]int)
	{
		searchIndexName, err := reader.ReadString()
		if err != nil { return nil, err }
		if searchIndexName != "{{search.name}}" { return nil, fmt.Errorf("expected search index {{search.name}} but found %s", searchIndexName) }
		searchMode, err := reader.ReadString()
		if err != nil { return nil, err }
		if searchMode != "{{search.mode}}" { return nil, fmt.Errorf("binary search mode does not match generated schema") }
		entryCount, err := reader.ReadInt32()
		if err != nil { return nil, err }
		if entryCount < 0 { return nil, fmt.Errorf("negative search index entry count") }
		for i := 0; i < int(entryCount); i++ {
%if search.is_enum
			rawKey, err := reader.ReadInt32()
			if err != nil { return nil, err }
			key := {{search.key_type}}(rawKey)
%else
			key, err := reader.{{search.read_method}}()
			if err != nil { return nil, err }
%endif
			valueCount, err := reader.ReadInt32()
			if err != nil { return nil, err }
			if valueCount < 0 { return nil, fmt.Errorf("negative search index value count") }
			ordinals := make([]int, int(valueCount))
			for j := 0; j < int(valueCount); j++ {
				ordinal, err := reader.ReadInt32()
				if err != nil { return nil, err }
				ordinals[j] = int(ordinal)
			}
			{{search.var_name}}[key] = ordinals
		}
	}
%endfor
	rowBlockLength, err := reader.ReadInt32()
	if err != nil {
		return nil, err
	}
	if rowBlockLength < 0 {
		return nil, fmt.Errorf("negative row block length")
	}
	rowBlockStart := reader.Position()
	if err := reader.Skip(int(rowBlockLength)); err != nil {
		return nil, err
	}
	for i := range rowOffsets {
		rowOffsets[i] += rowBlockStart
	}
%for idx in entry.indexes
%if idx.is_unique
	for key, offset := range {{idx.var_name}} {
		{{idx.var_name}}[key] = rowBlockStart + offset
	}
%else
	for key, offsets := range {{idx.var_name}} {
		for i := range offsets {
			offsets[i] += rowBlockStart
		}
		{{idx.var_name}}[key] = offsets
	}
%endif
%endfor
	return &{{entry.table_name}}{
		owner: owner,
		rowOffsets: rowOffsets,
%for idx in entry.indexes
		{{idx.var_name}}: {{idx.var_name}},
%endfor
%for search in entry.search_indexes
		{{search.var_name}}: {{search.var_name}},
%endfor
	}, nil
}

%endfor
type {{binary_container_name}} struct {
%for entry in entries
	{{entry.member_name}} []*{{entry.def.name}}
%endfor
}

type {{context_name}} struct {
	owner *BinaryDocumentOwner
%for entry in entries
	{{entry.member_name}} *{{entry.table_name}}
%endfor
}

func Open{{context_name}}(input []byte) (*{{context_name}}, error) {
	owner := NewBinaryDocumentOwner(input)
	reader := NewBinaryRefCursor(input)
	if err := BinaryRefReadHeader(reader); err != nil {
		return nil, err
	}
	tableCount, err := reader.ReadInt32()
	if err != nil {
		return nil, err
	}
	if tableCount != {{entry_count}} {
		return nil, fmt.Errorf("unexpected table count: %d", tableCount)
	}
%for entry in entries
	{{entry.member_name}}, err := read{{entry.table_name}}(owner, reader)
	if err != nil {
		return nil, err
	}
%endfor
	return &{{context_name}}{
		owner: owner,
%for entry in entries
		{{entry.member_name}}: {{entry.member_name}},
%endfor
	}, nil
}

func Save{{context_name}}(container *{{binary_container_name}}) ([]byte, error) {
	var buf bytes.Buffer
	writer := NewBinaryWriter(&buf)
	if err := BinaryRefWriteHeader(writer); err != nil {
		return nil, err
	}
	if err := writer.WriteInt32({{entry_count}}); err != nil {
		return nil, err
	}
%for entry in entries
	if err := ({{entry.table_name}}{}).write(writer, container.{{entry.member_name}}); err != nil {
		return nil, err
	}
%endfor
	return buf.Bytes(), nil
}
