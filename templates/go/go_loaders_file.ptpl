func (c *{{container_name}}) Load{{entry.def.name}}sFromBinary(path string) error {
	rows, err := Load{{entry.def.name}}sFromBinary(path)
	if err != nil {
		return err
	}
	c.{{entry.member_name}}.LoadAll(rows)
	return nil
}

%endfor
func (c *{{container_name}}) LoadFromCsv(root string) error {
%for entry in entries
%if entry.csv_pattern != ""
	if err := c.Load{{entry.def.name}}sFromCsv(filepath.Join(root, "{{entry.csv_pattern}}")); err != nil {
