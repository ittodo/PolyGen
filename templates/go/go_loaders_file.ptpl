}

func csvParseOptionalJSON[T any](row *CsvRow, column string) (*T, error) {
	raw, ok := row.Get(column)
	if !ok || strings.TrimSpace(raw) == "" {
		return nil, nil
	}
	var value T
	if err := json.Unmarshal([]byte(raw), &value); err != nil {
		return nil, fmt.Errorf("invalid CSV column %q JSON value %q: %w", column, raw, err)
	}
	return &value, nil
}

func csvParseListJSON[T any](row *CsvRow, column string) ([]T, error) {
	raw, ok := row.Get(column)
	if !ok || strings.TrimSpace(raw) == "" {
		return nil, nil
