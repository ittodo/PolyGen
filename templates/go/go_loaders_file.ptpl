	count, err := reader.ReadUint32()
	if err != nil {
		return nil, err
	}
	result := make([]*{{entry.def.name}}, 0, int(count))
	for i := uint32(0); i < count; i++ {
		value, err := Read{{entry.def.name}}Binary(reader)
		if err != nil {
			return nil, err
		}
		result = append(result, &value)
	}
	return result, nil
}

func Save{{entry.def.name}}sToBinary(path string, rows []*{{entry.def.name}}) error {
	var buf bytes.Buffer
	writer := NewBinaryWriter(&buf)
	if err := writer.WriteUint32(uint32(len(rows))); err != nil {
		return err
	}
	for _, row := range rows {
		if err := row.WriteBinary(writer); err != nil {
			return err
		}
	}
	return os.WriteFile(path, buf.Bytes(), 0644)
}

func (c *{{container_name}}) Load{{entry.def.name}}sFromCsv(path string) error {
	rows, err := Load{{entry.def.name}}sFromCsv(path)
	if err != nil {
		return err
	}
	c.{{entry.member_name}}.LoadAll(rows)
	return nil
}

