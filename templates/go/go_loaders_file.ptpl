%logic
// Go generated CSV/JSON/Binary loaders.

fn go_loader_base_type(t) {
    if t.is_option {
        return t.inner;
    }
    if t.is_list {
        return t.inner;
    }
    return t;
}

fn go_loader_value_parser(t) {
    let base = go_loader_base_type(t);
    let name = if base.lang_type != "" { base.lang_type } else { base.type_name };
    if name == "string" { return "csvParseStringValue"; }
    if name == "bytes" { return "csvParseBytesValue"; }
    if name == "bool" { return "csvParseBoolValue"; }
    if name == "u8" { return "csvParseUint8Value"; }
    if name == "u16" { return "csvParseUint16Value"; }
    if name == "u32" { return "csvParseUint32Value"; }
    if name == "u64" { return "csvParseUint64Value"; }
    if name == "i8" { return "csvParseInt8Value"; }
    if name == "i16" { return "csvParseInt16Value"; }
    if name == "i32" { return "csvParseInt32Value"; }
    if name == "i64" { return "csvParseInt64Value"; }
    if name == "f32" { return "csvParseFloat32Value"; }
    if name == "f64" { return "csvParseFloat64Value"; }
    if base.is_enum { return "csvParse" + go_lang_type(base) + "Value"; }
    return "";
}

fn go_loader_csv_expr(f) {
    let t = f.field_type;
    let parser = go_loader_value_parser(t);
    let base = go_loader_base_type(t);
    if parser == "" {
        let col = "\"" + to_snake_case(f.name) + "\"";
        if t.is_option && t.inner.is_struct {
            return "csvParseOptionalJSON[" + go_lang_type(t.inner) + "](row, " + col + ")";
        }
        if t.is_list && t.inner.is_struct {
            return "csvParseListJSON[" + go_lang_type(t.inner) + "](row, " + col + ")";
        }
        if base.is_struct {
            return "csvParseRequiredJSON[" + go_lang_type(base) + "](row, " + col + ")";
        }
        return "";
    }
    let col = "\"" + to_snake_case(f.name) + "\"";
    if t.is_option {
        return "csvParseOptional[" + go_lang_type(t.inner) + "](row, " + col + ", " + parser + ")";
    }
    if t.is_list {
        let inner = t.inner;
        if inner.is_struct || inner.lang_type == "bytes" || inner.type_name == "bytes" {
            return "";
        }
        return "csvParseList[" + go_lang_type(inner) + "](row, " + col + ", " + parser + ")";
    }
    return "csvParseRequired[" + go_lang_type(t) + "](row, " + col + ", " + parser + ")";
}

fn go_loader_zero_value(t) {
    if t.is_option || t.is_list {
        return "nil";
    }
    let name = if t.lang_type != "" { t.lang_type } else { t.type_name };
    if name == "string" { return "\"\""; }
    if name == "bytes" { return "nil"; }
    if name == "bool" { return "false"; }
    if t.is_enum { return "0"; }
    if t.is_primitive { return "0"; }
    return go_lang_type(t) + "{}";
}

fn go_binary_reader_method(t) {
    let name = if t.lang_type != "" { t.lang_type } else { t.type_name };
    if name == "string" { return "ReadString"; }
    if name == "bytes" { return "ReadBytes"; }
    if name == "bool" { return "ReadBool"; }
    if name == "u8" { return "ReadUint8"; }
    if name == "u16" { return "ReadUint16"; }
    if name == "u32" { return "ReadUint32"; }
    if name == "u64" { return "ReadUint64"; }
    if name == "i8" { return "ReadInt8"; }
    if name == "i16" { return "ReadInt16"; }
    if name == "i32" { return "ReadInt32"; }
    if name == "i64" { return "ReadInt64"; }
    if name == "f32" { return "ReadFloat32"; }
    if name == "f64" { return "ReadFloat64"; }
    return "";
}

fn go_binary_writer_method(t) {
    let name = if t.lang_type != "" { t.lang_type } else { t.type_name };
    if name == "string" { return "WriteString"; }
    if name == "bytes" { return "WriteBytes"; }
    if name == "bool" { return "WriteBool"; }
    if name == "u8" { return "WriteUint8"; }
    if name == "u16" { return "WriteUint16"; }
    if name == "u32" { return "WriteUint32"; }
    if name == "u64" { return "WriteUint64"; }
    if name == "i8" { return "WriteInt8"; }
    if name == "i16" { return "WriteInt16"; }
    if name == "i32" { return "WriteInt32"; }
    if name == "i64" { return "WriteInt64"; }
    if name == "f32" { return "WriteFloat32"; }
    if name == "f64" { return "WriteFloat64"; }
    return "";
}

fn go_binary_read_direct_expr(t, reader_expr) {
    if t.is_enum {
        return "binaryRead" + go_lang_type(t) + "Value(" + reader_expr + ")";
    }
    let method = go_binary_reader_method(t);
    if method != "" {
        return reader_expr + "." + method + "()";
    }
    return "Read" + t.type_name + "Binary(" + reader_expr + ")";
}

fn go_binary_read_expr(t, reader_expr) {
    if t.is_option {
        return "binaryReadOptional[" + go_lang_type(t.inner) + "](" + reader_expr + ", func(r *BinaryReader) (" + go_lang_type(t.inner) + ", error) { return " + go_binary_read_direct_expr(t.inner, "r") + " })";
    }
    if t.is_list {
        return "binaryReadList[" + go_lang_type(t.inner) + "](" + reader_expr + ", func(r *BinaryReader) (" + go_lang_type(t.inner) + ", error) { return " + go_binary_read_direct_expr(t.inner, "r") + " })";
    }
    return go_binary_read_direct_expr(t, reader_expr);
}

fn go_binary_write_direct_expr(t, value_expr, writer_expr) {
    if t.is_enum {
        return "binaryWrite" + go_lang_type(t) + "Value(" + writer_expr + ", " + value_expr + ")";
    }
    let method = go_binary_writer_method(t);
    if method != "" {
        return writer_expr + "." + method + "(" + value_expr + ")";
    }
    return value_expr + ".WriteBinary(" + writer_expr + ")";
}

fn go_binary_write_expr(t, value_expr, writer_expr) {
    if t.is_option {
        return "binaryWriteOptional[" + go_lang_type(t.inner) + "](" + writer_expr + ", " + value_expr + ", func(w *BinaryWriter, item " + go_lang_type(t.inner) + ") error { return " + go_binary_write_direct_expr(t.inner, "item", "w") + " })";
    }
    if t.is_list {
        return "binaryWriteList[" + go_lang_type(t.inner) + "](" + writer_expr + ", " + value_expr + ", func(w *BinaryWriter, item " + go_lang_type(t.inner) + ") error { return " + go_binary_write_direct_expr(t.inner, "item", "w") + " })";
    }
    return go_binary_write_direct_expr(t, value_expr, writer_expr);
}

fn collect_tables_from_namespace(ns) {
    let tables = [];
    for item in ns.items {
        if item.is_struct() {
            let s = item.as_struct();
            if !s.is_embed {
                tables.push(s);
            }
        } else if item.is_namespace() {
            let child_tables = collect_tables_from_namespace(item.as_namespace());
            for child in child_tables {
                tables.push(child);
            }
        }
    }
    tables
}

fn collect_structs_from_struct(s) {
    let structs = [s];
    for item in s.items {
        if item.is_embedded_struct() {
            let child_structs = collect_structs_from_struct(item.as_embedded_struct());
            for child in child_structs {
                structs.push(child);
            }
        }
    }
    return structs;
}

fn collect_enums_from_struct(s) {
    let enums = [];
    for item in s.items {
        if item.is_inline_enum() {
            enums.push(item.as_inline_enum());
        } else if item.is_embedded_struct() {
            let child_enums = collect_enums_from_struct(item.as_embedded_struct());
            for child in child_enums {
                enums.push(child);
            }
        }
    }
    return enums;
}

fn collect_enums_from_namespace(ns) {
    let enums = [];
    for item in ns.items {
        if item.is_enum() {
            enums.push(item.as_enum());
        } else if item.is_struct() {
            let struct_enums = collect_enums_from_struct(item.as_struct());
            for enum_def in struct_enums {
                enums.push(enum_def);
            }
        } else if item.is_namespace() {
            let child_enums = collect_enums_from_namespace(item.as_namespace());
            for child in child_enums {
                enums.push(child);
            }
        }
    }
    return enums;
}

fn collect_structs_from_namespace(ns) {
    let structs = [];
    for item in ns.items {
        if item.is_struct() {
            let item_structs = collect_structs_from_struct(item.as_struct());
            for s in item_structs {
                structs.push(s);
            }
        } else if item.is_namespace() {
            let child_structs = collect_structs_from_namespace(item.as_namespace());
            for child in child_structs {
                structs.push(child);
            }
        }
    }
    return structs;
}

let all_tables = [];
let all_structs = [];
let all_enums = [];
for ns in file.namespaces {
    let tables = collect_tables_from_namespace(ns);
    for s in tables {
        all_tables.push(s);
    }
    let structs = collect_structs_from_namespace(ns);
    for s in structs {
        all_structs.push(s);
    }
    let enums = collect_enums_from_namespace(ns);
    for enum_def in enums {
        all_enums.push(enum_def);
    }
}

let enum_entries = [];
for enum_def in all_enums {
    let members = [];
    for item in enum_def.items {
        if item.is_member() {
            let member = item.as_member();
            members.push(#{
                raw_name: member.name,
                raw_name_lower: member.name.to_lower(),
                const_name: enum_def.name + member.name,
                const_name_lower: (enum_def.name + member.name).to_lower()
            });
        }
    }
    enum_entries.push(#{
        name: enum_def.name,
        members: members
    });
}

let struct_entries = [];
for s in all_structs {
    let fields = [];
    for item in s.items {
        if item.is_field() {
            let f = as_field(item);
            fields.push(#{
                def: f,
                go_name: to_pascal_case(f.name),
                go_type: go_lang_type(f.field_type),
                var_name: to_camel_case(f.name),
                binary_read_expr: go_binary_read_expr(f.field_type, "reader"),
                binary_write_expr: go_binary_write_expr(f.field_type, "value." + to_pascal_case(f.name), "writer")
            });
        }
    }
    struct_entries.push(#{
        def: s,
        fields: fields
    });
}

let entries = [];
for s in all_tables {
    let fields = [];
    for item in s.items {
        if item.is_field() {
            let f = as_field(item);
            fields.push(#{
                def: f,
                go_name: to_pascal_case(f.name),
                go_type: go_lang_type(f.field_type),
                var_name: to_camel_case(f.name),
                csv_expr: go_loader_csv_expr(f),
                zero_value: go_loader_zero_value(f.field_type)
            });
        }
    }

    let csv_pattern = "";
    let json_pattern = "";
    if s.load != () {
        if s.load.csv != () {
            csv_pattern = s.load.csv;
        }
        if s.load.json != () {
            json_pattern = s.load.json;
        }
    }

    entries.push(#{
        def: s,
        fields: fields,
        member_name: to_pascal_case(s.name) + "s",
        csv_pattern: csv_pattern,
        json_pattern: json_pattern
    });
}

let base_name = file.path;
if base_name.contains("/") {
    let parts = base_name.split("/");
    base_name = parts[parts.len() - 1];
}
if base_name.ends_with(".poly") {
    base_name = base_name.sub_string(0, base_name.len() - 5);
}
let container_name = to_pascal_case(base_name) + "Container";
%endlogic
