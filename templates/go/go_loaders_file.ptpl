type csvValueParser[T any] func(string) (T, error)

func csvParseRequired[T any](row *CsvRow, column string, parse csvValueParser[T]) (T, error) {
	raw, ok := row.Get(column)
	var zero T
	if !ok {
		return zero, fmt.Errorf("missing required CSV column %q", column)
	}
	value, err := parse(raw)
	if err != nil {
		return zero, fmt.Errorf("invalid CSV column %q value %q: %w", column, raw, err)
	}
	return value, nil
}

func csvParseOptional[T any](row *CsvRow, column string, parse csvValueParser[T]) (*T, error) {
	raw, ok := row.Get(column)
	if !ok || strings.TrimSpace(raw) == "" {
		return nil, nil
	}
	value, err := parse(raw)
	if err != nil {
		return nil, fmt.Errorf("invalid CSV column %q value %q: %w", column, raw, err)
	}
	return &value, nil
}

func csvParseList[T any](row *CsvRow, column string, parse csvValueParser[T]) ([]T, error) {
	raw, ok := row.Get(column)
	if !ok || strings.TrimSpace(raw) == "" {
		return nil, nil
	}
	parts := strings.Split(raw, ",")
	values := make([]T, 0, len(parts))
	for _, part := range parts {
		trimmed := strings.TrimSpace(part)
		if trimmed == "" {
			continue
		}
		value, err := parse(trimmed)
		if err != nil {
			return nil, fmt.Errorf("invalid CSV column %q list item %q: %w", column, trimmed, err)
		}
		values = append(values, value)
	}
	return values, nil
}

func csvParseRequiredJSON[T any](row *CsvRow, column string) (T, error) {
	raw, ok := row.Get(column)
