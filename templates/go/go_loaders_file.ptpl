func (c *{{container_name}}) LoadFromCsvDirectory(dir string) error {
%for entry in entries
	{{entry.def.name | camel_case}}CsvPath := filepath.Join(dir, "{{entry.def.name}}.csv")
	if _, err := os.Stat({{entry.def.name | camel_case}}CsvPath); err == nil {
		if err := c.Load{{entry.def.name}}sFromCsv({{entry.def.name | camel_case}}CsvPath); err != nil {
			return err
		}
	} else if !os.IsNotExist(err) {
