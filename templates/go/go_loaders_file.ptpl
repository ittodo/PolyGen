	if !ok {
		return value, fmt.Errorf("missing required CSV column %q", column)
	}
	if err := json.Unmarshal([]byte(raw), &value); err != nil {
		return value, fmt.Errorf("invalid CSV column %q JSON value %q: %w", column, raw, err)
	}
