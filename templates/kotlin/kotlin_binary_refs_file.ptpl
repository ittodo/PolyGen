}

private fun readU32(bytes: ByteArray, offset: Int): Pair<Int, Int> {
    if (offset + 4 > bytes.size) {
        throw IllegalArgumentException("Unexpected end of PolyGen BinaryRef package.")
    }
    val value = ByteBuffer.wrap(bytes, offset, 4).order(ByteOrder.LITTLE_ENDIAN).int
    return value to offset + 4
}

