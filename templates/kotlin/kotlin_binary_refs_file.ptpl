private fun binaryRefSearchNormalize(value: String, policy: String): String {
    var result = value
    if (policy == "trim" || policy == "lower_trim") {
        result = result.trim()
    }
    if (policy == "lower" || policy == "lower_trim") {
        result = result.lowercase()
    }
    return result
}

private fun binaryRefSearchTokens(value: String, mode: String, n: Int, min: Int, normalize: String): List<String> {
    val normalized = binaryRefSearchNormalize(value, normalize)
    val tokens = linkedSetOf<String>()
    when (mode) {
        "exact" -> if (normalized.isNotEmpty() || min <= 0) tokens.add(normalized)
        "word" -> normalized.split(Regex("\\s+"))
            .filter { it.length >= min }
            .forEach { tokens.add(it) }
        else -> {
            require(n > 0) { "search ngram size must be positive" }
            if (normalized.length >= maxOf(n, min)) {
                for (index in 0..(normalized.length - n)) {
                    val token = normalized.substring(index, index + n)
                    if (token.length >= min) {
                        tokens.add(token)
                    }
                }
            }
        }
    }
    return tokens.toList()
}

