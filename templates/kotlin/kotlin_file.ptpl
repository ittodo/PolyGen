        val result = bytes.copyOfRange(offset, offset + size)
        offset += size
        return result
    }

    private fun buffer(size: Int): ByteBuffer =
        ByteBuffer.wrap(readExact(size)).order(ByteOrder.LITTLE_ENDIAN)

    fun readU8(): Int = buffer(1).get().toInt() and 0xff
    fun readI8(): Int = buffer(1).get().toInt()
    fun readU16(): Int = buffer(2).short.toInt() and 0xffff
    fun readI16(): Int = buffer(2).short.toInt()
    fun readU32(): Int = buffer(4).int
    fun readI32(): Int = buffer(4).int
    fun readU64(): Long = buffer(8).long
    fun readI64(): Long = buffer(8).long
    fun readF32(): Float = buffer(4).float
    fun readF64(): Double = buffer(8).double
    fun readBool(): Boolean = readU8() != 0
    fun readBytes(): ByteArray = readExact(readU32())
    fun readString(): String = String(readBytes(), Charsets.UTF_8)
