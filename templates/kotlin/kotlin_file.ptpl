    fun writeI8(value: Int) { writeExact(byteArrayOf(value.toByte())) }
    fun writeU16(value: Int) { writeExact(buffer(2).putShort(value.toShort()).array()) }
    fun writeI16(value: Int) { writeExact(buffer(2).putShort(value.toShort()).array()) }
    fun writeU32(value: Int) { writeExact(buffer(4).putInt(value).array()) }
    fun writeI32(value: Int) { writeExact(buffer(4).putInt(value).array()) }
    fun writeU64(value: Long) { writeExact(buffer(8).putLong(value).array()) }
    fun writeI64(value: Long) { writeExact(buffer(8).putLong(value).array()) }
    fun writeF32(value: Float) { writeExact(buffer(4).putFloat(value).array()) }
    fun writeF64(value: Double) { writeExact(buffer(8).putDouble(value).array()) }
