    fun <T> writeList(value: List<T>, writer: (PolygenBinaryWriter, T) -> Unit) {
        writeU32(value.size)
        value.forEach { writer(this, it) }
    }
}

private fun polygenIsEmpty(value: String?): Boolean = value == null || value.isEmpty()

private fun polygenRequired(value: String?, fieldName: String): String =
    if (polygenIsEmpty(value)) throw IllegalArgumentException("missing required field $fieldName") else value!!

private fun polygenReadCsvRows(path: String): List<Map<String, String>> {
    val lines = File(path).readLines()
    if (lines.isEmpty()) {
        return emptyList()
    }
    val headers = polygenSplitCsvLine(lines.first())
    return lines.drop(1)
        .filter { it.isNotBlank() }
        .map { line ->
            val values = polygenSplitCsvLine(line)
            headers.mapIndexed { index, header -> header to values.getOrElse(index) { "" } }.toMap()
        }
}

private fun polygenSplitCsvLine(line: String): List<String> {
    val values = mutableListOf<String>()
    val current = StringBuilder()
    var inQuotes = false
    var index = 0
    while (index < line.length) {
        val ch = line[index]
        if (ch == '"') {
            if (inQuotes && index + 1 < line.length && line[index + 1] == '"') {
                current.append('"')
                index += 1
            } else {
                inQuotes = !inQuotes
            }
        } else if (ch == ',' && !inQuotes) {
            values.add(current.toString())
            current.clear()
        } else {
            current.append(ch)
        }
        index += 1
    }
    values.add(current.toString())
    return values
}

private fun <T> polygenParseList(raw: String?, fieldName: String, parser: (String) -> T): List<T> {
    if (polygenIsEmpty(raw)) {
        return emptyList()
    }
    return polygenRequired(raw, fieldName)
        .split(",")
        .map { it.trim() }
        .filter { it.isNotEmpty() }
        .map(parser)
}

private fun polygenParseBool(raw: String, fieldName: String): Boolean = when (raw.trim().lowercase()) {
    "true", "1", "yes" -> true
    "false", "0", "no" -> false
    else -> throw IllegalArgumentException("invalid bool for $fieldName: $raw")
}

private fun polygenParseInt(raw: String, fieldName: String, unsigned: Boolean = false): Int {
    val parsed = raw.trim().toIntOrNull() ?: throw IllegalArgumentException("invalid integer for $fieldName: $raw")
    require(!unsigned || parsed >= 0) { "invalid unsigned integer for $fieldName: $raw" }
    return parsed
}

private fun polygenParseLong(raw: String, fieldName: String, unsigned: Boolean = false): Long {
    val parsed = raw.trim().toLongOrNull() ?: throw IllegalArgumentException("invalid long for $fieldName: $raw")
    require(!unsigned || parsed >= 0L) { "invalid unsigned long for $fieldName: $raw" }
    return parsed
}

private fun polygenParseFloat(raw: String, fieldName: String): Float {
    val parsed = raw.trim().toFloatOrNull() ?: throw IllegalArgumentException("invalid float for $fieldName: $raw")
    require(parsed.isFinite()) { "invalid finite float for $fieldName: $raw" }
    return parsed
}

private fun polygenParseDouble(raw: String, fieldName: String): Double {
    val parsed = raw.trim().toDoubleOrNull() ?: throw IllegalArgumentException("invalid double for $fieldName: $raw")
    require(parsed.isFinite()) { "invalid finite double for $fieldName: $raw" }
    return parsed
}

private inline fun <reified T : Enum<T>> polygenParseEnumValue(raw: String, fieldName: String, valueOf: (T) -> Int): Int {
    val trimmed = raw.trim()
    val numeric = trimmed.toIntOrNull()
    if (numeric != null) {
        return numeric
    }
    return try {
        valueOf(enumValueOf<T>(trimmed))
    } catch (exc: IllegalArgumentException) {
        throw IllegalArgumentException("invalid enum for $fieldName: $raw", exc)
    }
}


