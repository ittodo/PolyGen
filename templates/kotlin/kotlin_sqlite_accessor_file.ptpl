%if tbl.has_pk
    fun {{tbl.get_method}}(key: Any): {{tbl.class_name}}? {
        connection.prepareStatement("SELECT {{tbl.columns}} FROM {{tbl.table_name}} WHERE {{tbl.pk_name}} = ?").use { statement ->
            statement.setObject(1, key)
            statement.executeQuery().use { rows ->
                return if (rows.next()) map{{tbl.class_name}}(rows) else null
