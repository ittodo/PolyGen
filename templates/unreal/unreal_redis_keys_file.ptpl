#pragma once

#include "CoreMinimal.h"

namespace PolygenRedisKeys
{
inline const TCHAR* KeyNamespace = TEXT("polygen");

FORCEINLINE FString Segment(const FString& Value)
{
    return Value;
}

FORCEINLINE FString Segment(const TCHAR* Value)
{
    return FString(Value);
}

template <typename T>
FORCEINLINE FString Segment(const T& Value)
{
    return LexToString(Value);
}

{{body}}
} // namespace PolygenRedisKeys
