%endfor
%endfor
%for nav in forward_navs
    UFUNCTION(BlueprintPure, Category = "PolyGen|Registry")
    bool {{nav.method_name}}(const {{nav.source_struct_name}}& Row, {{nav.target_struct_name}}& OutRow) const
