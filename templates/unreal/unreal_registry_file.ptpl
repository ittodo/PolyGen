            Postings.Add(*RowsForToken);
        }
        return PolygenRegistryDetail::RowsFromIndices({{table.rows_member}}, PolygenRegistryDetail::IntersectPostings(Postings));
    }
%blank
%else
    UFUNCTION(BlueprintPure, Category = "PolyGen|Registry")
    TArray<{{table.struct_name}}> {{search.function_name}}({{search.key_type}} Query) const
    {
        const TArray<int32>* RowIndices = {{search.member_name}}.Find({{search.query_expr}});
        return RowIndices == nullptr ? TArray<{{table.struct_name}}>() : PolygenRegistryDetail::RowsFromIndices({{table.rows_member}}, *RowIndices);
    }
