%blank
%endif
%endfor
%for search in table.search_indexes
%if search.is_token_mode
    UFUNCTION(BlueprintPure, Category = "PolyGen|Registry")
    TArray<{{table.struct_name}}> {{search.function_name}}(const FString& Query) const
    {
        const TArray<FString> Tokens = PolygenRegistryDetail::SearchTokens(Query, TEXT("{{search.mode}}"), {{search.n}}, {{search.min}}, TEXT("{{search.normalize}}"));
        TArray<TArray<int32>> Postings;
        for (const FString& Token : Tokens)
        {
            const TArray<int32>* RowsForToken = {{search.member_name}}.Find(Token);
            if (RowsForToken == nullptr)
