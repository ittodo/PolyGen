%blank
%for idx in table.indexes
%if idx.is_unique
    UFUNCTION(BlueprintPure, Category = "PolyGen|Registry")
    bool {{idx.find_name}}({{idx.key_type}} Key, {{table.struct_name}}& OutRow) const
    {
        const int32* RowIndex = {{idx.member_name}}.Find(Key);
        if (RowIndex == nullptr || !{{table.rows_member}}.IsValidIndex(*RowIndex))
        {
            return false;
