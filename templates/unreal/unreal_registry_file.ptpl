%for table in tables
%if table.field_checks.len() > 0
        for (int32 RowIndex = 0; RowIndex < {{table.rows_member}}.Num(); ++RowIndex)
        {
            const {{table.struct_name}}& Row = {{table.rows_member}}[RowIndex];
%for check in table.field_checks
%if check.kind == "max_length"
            if ({{check.length_expr}} > {{check.limit}})
            {
                FPolygenRegistryValidationError Error;
                Error.TableName = TEXT("{{table.table_name}}");
                Error.FieldName = TEXT("{{check.field_name}}");
                Error.ConstraintType = TEXT("MaxLength");
                Error.Message = FString::Printf(TEXT("Length for {{table.table_name}}.{{check.field_name}} exceeds maximum {{check.limit}} at row %d"), RowIndex);
                OutErrors.Add(Error);
            }
%elif check.kind == "range"
            if ({{check.value_expr}} < {{check.min}} || {{check.value_expr}} > {{check.max}})
            {
                FPolygenRegistryValidationError Error;
                Error.TableName = TEXT("{{table.table_name}}");
                Error.FieldName = TEXT("{{check.field_name}}");
                Error.ConstraintType = TEXT("Range");
                Error.Message = FString::Printf(TEXT("Value for {{table.table_name}}.{{check.field_name}} is outside range [{{check.min}}, {{check.max}}] at row %d"), RowIndex);
                OutErrors.Add(Error);
            }
%elif check.kind == "regex"
            {
                const FRegexPattern {{check.pattern_name}}({{check.pattern_literal}});
                FRegexMatcher {{check.matcher_name}}({{check.pattern_name}}, {{check.value_expr}});
                if (!{{check.matcher_name}}.FindNext())
                {
                    FPolygenRegistryValidationError Error;
                    Error.TableName = TEXT("{{table.table_name}}");
                    Error.FieldName = TEXT("{{check.field_name}}");
                    Error.ConstraintType = TEXT("Regex");
                    Error.Message = FString::Printf(TEXT("Value for {{table.table_name}}.{{check.field_name}} does not match regex at row %d"), RowIndex);
                    OutErrors.Add(Error);
                }
            }
%endif
%endfor
        }
%endif
%endfor
        return OutErrors.Num() == 0;
    }
%blank
    UFUNCTION(BlueprintCallable, Category = "PolyGen|Registry")
    bool ValidateUniqueKeys(TArray<FPolygenRegistryValidationError>& OutErrors) const
    {
        OutErrors.Reset();
%for table in tables
%for idx in table.indexes
%if idx.is_unique
        {
            TSet<{{idx.key_type}}> {{idx.seen_name}};
            for (int32 RowIndex = 0; RowIndex < {{table.rows_member}}.Num(); ++RowIndex)
            {
                const {{table.struct_name}}& Row = {{table.rows_member}}[RowIndex];
                const {{idx.key_type}} {{idx.key_name}} = {{idx.key_expr}};
                if ({{idx.seen_name}}.Contains({{idx.key_name}}))
                {
                    FPolygenRegistryValidationError Error;
                    Error.TableName = TEXT("{{table.table_name}}");
                    Error.FieldName = TEXT("{{idx.field_name}}");
                    Error.ConstraintType = TEXT("Unique");
                    Error.Message = FString::Printf(TEXT("Duplicate key for {{table.table_name}}.{{idx.field_name}} at row %d"), RowIndex);
                    OutErrors.Add(Error);
                }
                else
                {
                    {{idx.seen_name}}.Add({{idx.key_name}});
                }
            }
        }
%endif
%endfor
%endfor
        return OutErrors.Num() == 0;
    }
%blank
    UFUNCTION(BlueprintCallable, Category = "PolyGen|Registry")
    bool ValidateForeignKeys(TArray<FPolygenRegistryValidationError>& OutErrors) const
    {
        OutErrors.Reset();
%for table in tables
%for fk in table.foreign_keys
        for (const {{table.struct_name}}& Row : {{table.rows_member}})
        {
            if (!{{fk.target_index_member}}.Contains(Row.{{fk.field_name}}))
            {
                FPolygenRegistryValidationError Error;
                Error.TableName = TEXT("{{table.table_name}}");
                Error.FieldName = TEXT("{{fk.field_name}}");
                Error.ConstraintType = TEXT("ForeignKey");
                Error.Message = FString::Printf(TEXT("Missing {{fk.target_table_fqn}}.{{fk.target_field}} reference for {{table.table_name}}.{{fk.field_name}}=%s"), *LexToString(Row.{{fk.field_name}}));
                OutErrors.Add(Error);
            }
        }
%endfor
%endfor
        return OutErrors.Num() == 0;
    }
%blank
    UFUNCTION(BlueprintCallable, Category = "PolyGen|Registry")
    bool ValidateAll(TArray<FPolygenRegistryValidationError>& OutErrors) const
    {
        OutErrors.Reset();
        TArray<FPolygenRegistryValidationError> FieldErrors;
        TArray<FPolygenRegistryValidationError> UniqueErrors;
        TArray<FPolygenRegistryValidationError> ForeignKeyErrors;
        const bool bFieldsValid = ValidateFieldConstraints(FieldErrors);
        const bool bUniqueValid = ValidateUniqueKeys(UniqueErrors);
        const bool bForeignKeysValid = ValidateForeignKeys(ForeignKeyErrors);
        OutErrors.Append(FieldErrors);
        OutErrors.Append(UniqueErrors);
        OutErrors.Append(ForeignKeyErrors);
        return bFieldsValid && bUniqueValid && bForeignKeysValid;
    }
%blank
private:
%for table in tables
    UPROPERTY(VisibleAnywhere, BlueprintReadOnly, Category = "PolyGen|Registry", meta = (AllowPrivateAccess = "true"))
    TArray<{{table.struct_name}}> {{table.rows_member}};
%blank
%for idx in table.indexes
%if idx.is_unique
    TMap<{{idx.key_type}}, int32> {{idx.member_name}};
%else
    TMap<{{idx.key_type}}, TArray<int32>> {{idx.member_name}};
%endif
%endfor
%for search in table.search_indexes
    TMap<{{search.key_type}}, TArray<int32>> {{search.member_name}};
%endfor
%blank
    void {{table.rebuild_function}}()
    {
%for idx in table.indexes
        {{idx.member_name}}.Reset();
%endfor
%for search in table.search_indexes
        {{search.member_name}}.Reset();
%endfor
        for (int32 RowIndex = 0; RowIndex < {{table.rows_member}}.Num(); ++RowIndex)
        {
            const {{table.struct_name}}& Row = {{table.rows_member}}[RowIndex];
%for idx in table.indexes
%if idx.is_unique
            {{idx.member_name}}.Add({{idx.key_expr}}, RowIndex);
%else
            {{idx.member_name}}.FindOrAdd({{idx.key_expr}}).Add(RowIndex);
%endif
%endfor
%for search in table.search_indexes
%if search.is_token_mode
            for (const FString& Token : PolygenRegistryDetail::SearchTokens({{search.value_expr}}, TEXT("{{search.mode}}"), {{search.n}}, {{search.min}}, TEXT("{{search.normalize}}")))
            {
                {{search.member_name}}.FindOrAdd(Token).Add(RowIndex);
            }
%else
            {{search.member_name}}.FindOrAdd({{search.index_expr}}).Add(RowIndex);
%endif
%endfor
        }
    }
%blank
%endfor
};
%endif
