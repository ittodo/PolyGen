export function load{{s.function_prefix}}sFromJson(path: string): {{s.type_name}}[] {
    const value = JSON.parse(polygenReadText(path)) as unknown;
    if (!Array.isArray(value)) {
        throw new PolygenLoadError("Expected top-level JSON array", "{{s.name}}", value);
    }
    return value.map(item => from{{s.function_prefix}}Json(item));
}

export function load{{s.function_prefix}}sFromCsv(path: string): {{s.type_name}}[] {
