%for s in struct_entries
export function from{{s.function_prefix}}Json(value: unknown): {{s.type_name}} {
    const obj = polygenObject(value, "{{s.type_name}}");
    return {
%for field in s.json_fields
        {{field.name}}: {{field.parsed_expr}},
%endfor
    };
}

export function from{{s.function_prefix}}Csv(row: Record<string, string>): {{s.type_name}} {
    return {
%for field in s.csv_fields
        {{field.name}}: {{field.parsed_expr}},
%endfor
