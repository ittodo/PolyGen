import { readFileSync } from "node:fs";
import { BinaryRefFormat, BinaryRefReader, BinaryRefWriter } from "./binary_ref";

export class PolygenLoadError extends Error {
    constructor(message: string, readonly fieldName?: string, readonly value?: unknown) {
        super(message);
        this.name = "PolygenLoadError";
    }
}

function polygenReadText(path: string): string {
    return readFileSync(path, "utf8");
}

function polygenSplitCsvLine(line: string): string[] {
    const result: string[] = [];
    let current = "";
    let inQuotes = false;
    for (let i = 0; i < line.length; i++) {
        const ch = line[i];
        if (ch === "\"") {
            if (inQuotes && line[i + 1] === "\"") {
                current += "\"";
                i += 1;
            } else {
                inQuotes = !inQuotes;
            }
        } else if (ch === "," && !inQuotes) {
            result.push(current);
            current = "";
        } else {
            current += ch;
        }
    }
    result.push(current);
    return result;
}

function polygenReadCsvRows(path: string): Record<string, string>[] {
    const text = polygenReadText(path).replace(/^\uFEFF/, "");
    const lines = text.split(/\r?\n/).filter(line => line.trim().length > 0);
    if (lines.length === 0) return [];
    const headers = polygenSplitCsvLine(lines[0]).map(header => header.trim());
    return lines.slice(1).map(line => {
        const values = polygenSplitCsvLine(line);
        const row: Record<string, string> = {};
        headers.forEach((header, index) => {
            row[header] = values[index] ?? "";
        });
        return row;
    });
}

function polygenIsEmpty(value: unknown): boolean {
    return value === undefined || value === null || value === "";
}

function polygenRequired(value: unknown, fieldName: string): unknown {
    if (polygenIsEmpty(value)) {
        throw new PolygenLoadError(`Missing required field: ${fieldName}`, fieldName, value);
    }
    return value;
}

function polygenObject(value: unknown, fieldName: string): Record<string, unknown> {
    const parsed = typeof value === "string" ? JSON.parse(value) as unknown : value;
    if (typeof parsed !== "object" || parsed === null || Array.isArray(parsed)) {
        throw new PolygenLoadError(`Expected object for field: ${fieldName}`, fieldName, value);
    }
    return parsed as Record<string, unknown>;
}

function polygenField(source: Record<string, unknown>, camelName: string, sourceName: string): unknown {
    if (Object.prototype.hasOwnProperty.call(source, camelName)) return source[camelName];
    return source[sourceName];
}

function polygenParseString(value: unknown, fieldName: string): string {
    if (typeof value === "string") return value;
    if (typeof value === "number" || typeof value === "boolean") return String(value);
    throw new PolygenLoadError(`Invalid string field: ${fieldName}`, fieldName, value);
}

function polygenParseBool(value: unknown, fieldName: string): boolean {
    if (typeof value === "boolean") return value;
    if (typeof value === "string") {
        const normalized = value.trim().toLowerCase();
        if (normalized === "true" || normalized === "1" || normalized === "yes") return true;
        if (normalized === "false" || normalized === "0" || normalized === "no") return false;
    }
    throw new PolygenLoadError(`Invalid bool field: ${fieldName}`, fieldName, value);
}

function polygenParseInteger(value: unknown, fieldName: string): number {
    const parsed = typeof value === "number" ? value : Number(String(value).trim());
    if (!Number.isInteger(parsed) || !Number.isFinite(parsed)) {
        throw new PolygenLoadError(`Invalid integer field: ${fieldName}`, fieldName, value);
    }
    return parsed;
}

function polygenParseFloat(value: unknown, fieldName: string): number {
    const parsed = typeof value === "number" ? value : Number(String(value).trim());
    if (!Number.isFinite(parsed)) {
        throw new PolygenLoadError(`Invalid number field: ${fieldName}`, fieldName, value);
    }
    return parsed;
}

function polygenParseDate(value: unknown, fieldName: string): Date {
    const date = value instanceof Date ? value : new Date(String(value));
    if (Number.isNaN(date.getTime())) {
        throw new PolygenLoadError(`Invalid timestamp field: ${fieldName}`, fieldName, value);
    }
    return date;
}

function polygenParseBytes(value: unknown, fieldName: string): Uint8Array {
    if (value instanceof Uint8Array) return value;
    if (Array.isArray(value)) return Uint8Array.from(value.map(item => polygenParseInteger(item, fieldName)));
    if (typeof value === "string") {
        const binary = atob(value);
        return Uint8Array.from(binary, ch => ch.charCodeAt(0));
    }
    throw new PolygenLoadError(`Invalid bytes field: ${fieldName}`, fieldName, value);
}

function polygenParseEnum<E extends Record<string, string | number>>(value: unknown, fieldName: string, enumType: E): E[keyof E] {
    const raw = String(value).trim();
    const numeric = Number(raw);
    if (Number.isInteger(numeric) && enumType[numeric] !== undefined) {
        return numeric as E[keyof E];
    }
    const named = enumType[raw as keyof E];
    if (typeof named === "number") {
        return named as E[keyof E];
    }
    throw new PolygenLoadError(`Invalid enum field: ${fieldName}`, fieldName, value);
}

function polygenParseArray<T>(value: unknown, fieldName: string, parser: (item: unknown) => T): T[] {
    if (polygenIsEmpty(value)) return [];
    let rawItems: unknown;
    if (typeof value === "string") {
        const trimmed = value.trim();
        rawItems = trimmed.startsWith("[") ? JSON.parse(trimmed) as unknown : trimmed.split(",").map(item => item.trim()).filter(item => item.length > 0);
    } else {
        rawItems = value;
    }
    if (!Array.isArray(rawItems)) {
        throw new PolygenLoadError(`Invalid array field: ${fieldName}`, fieldName, value);
    }
    return rawItems.map(parser);
}

function polygenReadBytes(reader: BinaryRefReader): Uint8Array {
    const length = reader.readI32();
    if (length < 0) {
        throw new PolygenLoadError("Negative binary payload length");
    }
    return reader.readBytes(length);
}

function polygenReadOptional<T>(reader: BinaryRefReader, read: () => T): T | undefined {
    return reader.readBool() ? read() : undefined;
}

function polygenWriteOptional<T>(writer: BinaryRefWriter, value: T | undefined | null, write: (value: T) => void): void {
    if (value === undefined || value === null) {
        writer.writeBool(false);
        return;
    }
    writer.writeBool(true);
    write(value);
}

function polygenReadList<T>(reader: BinaryRefReader, read: () => T): T[] {
    const length = reader.readI32();
    if (length < 0) {
        throw new PolygenLoadError("Negative binary list length");
    }
    const values: T[] = [];
    for (let index = 0; index < length; index++) {
        values.push(read());
    }
    return values;
}

function polygenWriteList<T>(writer: BinaryRefWriter, values: T[], write: (value: T) => void): void {
    writer.writeI32(values.length);
    for (const value of values) {
        write(value);
    }
}

function polygenReadEnum<E extends Record<string, string | number>>(enumType: E, value: number, enumName: string): E[keyof E] {
    if (Number.isInteger(value) && enumType[value] !== undefined) {
        return value as E[keyof E];
    }
    throw new PolygenLoadError(`Invalid enum value for ${enumName}: ${value}`, enumName, value);
}

function polygenWriteEnum<E extends Record<string, string | number>>(writer: BinaryRefWriter, enumType: E, value: number, enumName: string): void {
    writer.writeI32(polygenReadEnum(enumType, value, enumName) as number);
}
