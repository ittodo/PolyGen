          "keyPattern": "polygen:game.cache:Session:idx:by_user_id:{value}"
        }
      ]
    },
    {
      "name": "game_cache_LeaderboardEntry",
      "fqn": "game.cache.LeaderboardEntry",
      "cacheStrategy": "on_demand",
      "ttlSeconds": null,
      "primaryKey": "id",
      "valueEncoding": "json",
      "entityKeyPattern": "polygen:game.cache:LeaderboardEntry:{id}",
      "allSetKey": "polygen:game.cache:LeaderboardEntry:all",
      "indexes": [
        {
          "name": "ById",
          "unique": true,
          "fields": ["id"],
          "keyPattern": "polygen:game.cache:LeaderboardEntry:idx:by_id:{value}"
        },
        {
          "name": "ByPlayerName",
          "unique": false,
          "fields": ["player_name"],
          "keyPattern": "polygen:game.cache:LeaderboardEntry:idx:by_player_name:{value}"
        },
        {
          "name": "ByScore",
          "unique": false,
          "fields": ["score"],
          "keyPattern": "polygen:game.cache:LeaderboardEntry:idx:by_score:{value}"
        }
      ]
    }
  ]
}

